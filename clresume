#!/usr/bin/env bash
# Lists saved Claude sessions and resumes user-chosen one.
#
# Sessions are recorded by the tracksession SessionStart hook into
# ~/.claude/tmux-sessions/, one file per tmux pane named by $TMUX_PANE.
# Each file contains: SESSION_ID TAB CWD
#
# Files are listed newest-first. Choosing one runs: claude --resume SESSION_ID
# Uses fzf for the picker if available, otherwise falls back to bash select.
#
# This command never auto-resumes. User must always choose explicitly.
set -euo pipefail

paneDir="$HOME/.claude/tmux-sessions"

if [[ ! -d "$paneDir" ]]; then
    echo "No sessions directory found at $paneDir" >&2
    exit 1
fi

realClaude="$(PATH="${PATH//$HOME\/bin:/}" command -v claude 2>/dev/null || echo "")"
if [[ -z "$realClaude" ]]; then
    echo "error: claude not found outside ~/bin" >&2
    exit 1
fi

# Build parallel arrays: sessionIds and display lines (newest first by mtime).
sessionIds=()
displayLines=()

while IFS= read -r sessionFile; do
    [[ -f "$sessionFile" ]] || continue
    IFS=$'\t' read -r sessionId sessionCwd < "$sessionFile" || true
    [[ -z "$sessionId" ]] && continue
    sessionIds+=("$sessionId")
    displayLines+=("$sessionCwd  (${sessionId:0:8}...)")
done < <(
    find "$paneDir" -maxdepth 1 -type f -printf '%T@\t%p\n' \
        | sort -rn \
        | cut -f2-
)

if [[ ${#sessionIds[@]} -eq 0 ]]; then
    echo "No saved sessions found in $paneDir" >&2
    exit 1
fi

chosenId=""

if command -v fzf &>/dev/null; then
    chosen=$(printf '%s\n' "${displayLines[@]}" \
        | fzf --prompt="Resume Claude session: " --height=~12 --reverse)
    [[ -z "$chosen" ]] && exit 0
    for i in "${!displayLines[@]}"; do
        if [[ "${displayLines[$i]}" == "$chosen" ]]; then
            chosenId="${sessionIds[$i]}"
            break
        fi
    done
else
    echo "Saved Claude sessions (newest first):" >&2
    PS3="Enter number to resume (0 to cancel): "
    select choice in "${displayLines[@]}" "Cancel"; do
        if [[ "$REPLY" == "0" ]] || [[ "$choice" == "Cancel" ]]; then
            echo "Cancelled." >&2
            exit 0
        fi
        idx=$((REPLY - 1))
        if [[ $idx -ge 0 ]] && [[ $idx -lt ${#sessionIds[@]} ]]; then
            chosenId="${sessionIds[$idx]}"
            break
        fi
    done
fi

if [[ -z "$chosenId" ]]; then
    echo "No session selected." >&2
    exit 1
fi

exec "$realClaude" --resume "$chosenId"
