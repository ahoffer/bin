#!/usr/bin/env bash
set -euo pipefail

# Indexes the JSONL session file created during this run into ~/logs/.
# Usage: wraplog TOOLNAME REALBINARY [ARGS...]

toolName="$1"
realBinary="$2"
shift 2

mkdir -p "$HOME/logs"
logPrefix="$HOME/logs/${toolName}-$(date +%Y%m%d-%H%M%S)"

case "$toolName" in
    claude) sessionDir="$HOME/.claude/projects" ;;
    codex)  sessionDir="$HOME/.codex/sessions" ;;
    *)      sessionDir="" ;;
esac

timeRef=$(mktemp)

cleanup() {
    exitCode=$?
    set +e
    if [[ -n "$sessionDir" && -f "$timeRef" ]]; then
        newSession=$(find "$sessionDir" -name "*.jsonl" ! -path "*/subagents/*" \
            -newer "$timeRef" -printf '%T@ %p\n' 2>/dev/null \
            | sort -rn | head -1 | cut -d' ' -f2- || true)
        if [[ -n "$newSession" ]]; then
            sessionId=$(basename "$newSession" .jsonl)
            if [[ -z "$(find "$HOME/logs" -maxdepth 1 -name "*-${sessionId}.jsonl" 2>/dev/null)" ]]; then
                ln -sf "$newSession" "${logPrefix}-${sessionId}.jsonl"
            fi
        fi
    fi
    rm -f "$timeRef"
    exit $exitCode
}
trap cleanup EXIT

"$realBinary" "$@"
