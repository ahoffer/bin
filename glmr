#!/usr/bin/env bash
# GitLab Merge Request viewer. Fetches MR details, linked issues, and comments.

set -euo pipefail

usage() {
    cat <<EOF
Usage: glmr <mr-url>

Fetches and displays GitLab Merge Request details including title, description,
linked issues, and all comments.

Example:
    glmr https://gitlab.octo-cx-prod.runshiftup.com/octo-cx/cx/cx-search/-/merge_requests/381

Environment:
    GITLAB_BOT_READ_TOKEN    Required. GitLab API token for authentication.

Requires:
    requestgitlab            Script for GitLab API access.
EOF
    exit 1
}

if [[ $# -lt 1 ]]; then
    usage
fi

mrurl="$1"

if [[ -z "${GITLAB_BOT_READ_TOKEN:-}" ]]; then
    echo "Error: GITLAB_BOT_READ_TOKEN is not set or empty." >&2
    echo "Restart with the token passed at launch:" >&2
    echo "    GITLAB_BOT_READ_TOKEN=\$GITLAB_BOT_READ_TOKEN claude" >&2
    exit 1
fi

if ! command -v requestgitlab &>/dev/null; then
    echo "Error: requestgitlab script not found in PATH." >&2
    exit 1
fi

# Parse the MR URL to extract components
# Expected format: https://gitlab.example.com/group/subgroup/project/-/merge_requests/123
if [[ ! "$mrurl" =~ ^(https?://[^/]+)/(.+)/-/merge_requests/([0-9]+)$ ]]; then
    echo "Error: Invalid MR URL format." >&2
    echo "Expected: https://gitlab.example.com/path/to/project/-/merge_requests/123" >&2
    exit 1
fi

baseurl="${BASH_REMATCH[1]}"
projectpath="${BASH_REMATCH[2]}"
mriid="${BASH_REMATCH[3]}"


echo "========================================"
echo "Merge Request: ${projectpath}!${mriid}"
echo "========================================"
echo

# Fetch MR details
mrjson=$(requestgitlab --raw "$mrurl")

# Check for API errors
if echo "$mrjson" | jq -e '.error // .message' >/dev/null 2>&1; then
    errormsg=$(echo "$mrjson" | jq -r '.error // .message')
    echo "Error fetching MR: $errormsg" >&2
    exit 1
fi

# Extract and display MR info
mrtitle=$(echo "$mrjson" | jq -r '.title // "No title"')
mrdescription=$(echo "$mrjson" | jq -r '.description // "No description"')
mrstate=$(echo "$mrjson" | jq -r '.state // "unknown"')
mrauthor=$(echo "$mrjson" | jq -r '.author.name // .author.username // "unknown"')
mrsourcebranch=$(echo "$mrjson" | jq -r '.source_branch // "unknown"')
mrtargetbranch=$(echo "$mrjson" | jq -r '.target_branch // "unknown"')
mrweburl=$(echo "$mrjson" | jq -r '.web_url // ""')

echo "TITLE: $mrtitle"
echo "STATE: $mrstate"
echo "AUTHOR: $mrauthor"
echo "BRANCHES: $mrsourcebranch -> $mrtargetbranch"
echo "URL: $mrweburl"
echo
echo "DESCRIPTION:"
echo "----------------------------------------"
echo "$mrdescription"
echo "----------------------------------------"
echo

# Find linked issues from the description
# Look for patterns like Closes #123, Fixes #123, Resolves #123, or full issue URLs
echo "LINKED ISSUES:"
echo "----------------------------------------"

linkedissues=""

# Extract issue numbers from patterns like Closes #123, Fixes #123, Resolves #123
issuenumbers=$(echo "$mrdescription" | grep -oEi '(closes?|fixes?|resolves?|related to)\s*#([0-9]+)' | grep -oE '[0-9]+' || true)

# Extract issue URLs from the same GitLab instance
issueurls=$(echo "$mrdescription" | grep -oE "${baseurl}/[^[:space:]]*/issues/[0-9]+" || true)

if [[ -n "$issuenumbers" ]]; then
    for issuenum in $issuenumbers; do
        # Fetch issue from the same project by constructing the web URL
        constructedissueurl="${baseurl}/${projectpath}/-/issues/${issuenum}"
        issuejson=$(requestgitlab --raw "$constructedissueurl" 2>/dev/null || echo '{}')
        issuetitle=$(echo "$issuejson" | jq -r '.title // empty')
        if [[ -n "$issuetitle" ]]; then
            issuestate=$(echo "$issuejson" | jq -r '.state // "unknown"')
            issueweburl=$(echo "$issuejson" | jq -r '.web_url // ""')
            echo "  #${issuenum}: ${issuetitle} [${issuestate}]"
            echo "    $issueweburl"
            linkedissues="found"
        fi
    done
fi

if [[ -n "$issueurls" ]]; then
    for issueurl in $issueurls; do
        # Parse the issue URL to get project and issue number
        if [[ "$issueurl" =~ ${baseurl}/(.+)/issues/([0-9]+)$ ]]; then
            issueprojectpath="${BASH_REMATCH[1]}"
            issuenum="${BASH_REMATCH[2]}"
            # Remove trailing /-/ if present and normalize to web URL format
            issueprojectpath="${issueprojectpath%/-}"
            normalizedissueurl="${baseurl}/${issueprojectpath}/-/issues/${issuenum}"
            issuejson=$(requestgitlab --raw "$normalizedissueurl" 2>/dev/null || echo '{}')
            issuetitle=$(echo "$issuejson" | jq -r '.title // empty')
            if [[ -n "$issuetitle" ]]; then
                issuestate=$(echo "$issuejson" | jq -r '.state // "unknown"')
                echo "  ${issueprojectpath}#${issuenum}: ${issuetitle} [${issuestate}]"
                echo "    $issueurl"
                linkedissues="found"
            fi
        fi
    done
fi

if [[ -z "$linkedissues" ]]; then
    echo "  No linked issues found in description."
fi
echo

# Fetch and display all notes/comments
echo "COMMENTS:"
echo "----------------------------------------"

notesjson=$(requestgitlab --raw "$mrurl" "notes?sort=asc&per_page=100")

notecount=$(echo "$notesjson" | jq 'length')

if [[ "$notecount" == "0" ]]; then
    echo "  No comments on this MR."
else
    echo "$notesjson" | jq -r '.[] |
        "[\(.created_at | split("T")[0])] \(.author.name // .author.username):\n\(.body)\n"
    '
fi

echo "========================================"
echo "End of MR ${projectpath}!${mriid}"
echo "========================================"
