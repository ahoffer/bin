#!/usr/bin/env perl
use strict;
use warnings;

# Collapse Maven's multi-line parallel thread-safety warning block into two
# lines: a short WARNING summary and a DEBUG line listing the unsafe plugins.
# The WARNING stays visible at the default level; plugin names appear at v4.
#
# In a parallel build, lines from other modules can interleave with the block.
# Interleaved lines are passed through immediately without aborting collection;
# the state machine matches continuation lines by content, not by timestamp
# prefix.

$| = 1;

my $in_block    = 0;
my $after_scope = 0;    # true after seeing the "following plugins" scope line
my $prefix      = '';   # timestamp prefix from the opening line
my $scope       = '';
my @plugins     = ();

sub emit_condensed {
    my $plugin_text = @plugins ? join(', ', @plugins) : 'unknown plugin';
    my $scope_text  = length($scope) ? " in $scope" : '';
    print $prefix . "WARNING Parallel build: not all plugins are thread-safe\n";
    print $prefix . 'DEBUG Thread-unsafe plugins' . $scope_text . ': ' . $plugin_text . "\n";
    $in_block    = 0;
    $after_scope = 0;
    $prefix      = '';
    $scope       = '';
    @plugins     = ();
}

while (my $line = <STDIN>) {
    if (!$in_block) {
        if ($line =~ /^(\S+\s+)WARNING\s+\* Your build is requesting parallel execution/) {
            $in_block    = 1;
            $after_scope = 0;
            $prefix      = $1;
            @plugins     = ();
            $scope       = '';
            next;
        }
        print $line;
        next;
    }

    # Boilerplate asterisk lines - suppress.
    if ($line =~ /^\S+\s+WARNING\s+\* /) {
        next;
    }

    # Scope line - extract the module name.
    if ($line =~ /^\S+\s+WARNING The following plugins are not marked as thread-safe in (.+):\s*$/) {
        $scope       = $1;
        $after_scope = 1;
        next;
    }

    # Closing line - emit the condensed summary.
    if ($line =~ /^\S+\s+WARNING Enable debug to see precisely which goals are not marked as thread-safe\./) {
        emit_condensed();
        next;
    }

    # Plugin coordinate line (groupId:artifactId:version), only valid after scope.
    if ($after_scope && $line =~ /^\S+\s+WARNING\s+([\w][\w.-]*:[\w.-]+:[\w.-]+)\s*$/) {
        push @plugins, $1;
        next;
    }

    # Interleaved line from another module - pass through, stay in block state.
    print $line;
}

# Stream ended while inside a block; emit whatever was collected.
emit_condensed() if $in_block;
