#!/usr/bin/env bash
set -euo pipefail

# Build component Docker images
#
# This script ONLY builds images. It does NOT push or deploy.
# After building, use cxdeploy to push images and restart pods.
# Must be run from within a project directory (walks up to find pom.xml).
#
# Usage: cxbuild [options] <component...>
#        cxbuild all
#        cxbuild app graphql
#
# Examples:
#   cxbuild graphql
#   cxbuild all

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
source "$SCRIPT_DIR/cx.lib"
timer_start

usage() {
  cat <<'EOF'
Build component Docker images

This script ONLY builds images. It does NOT push or deploy.
After building, use cxdeploy to push images and restart pods.

Usage: cxbuild [options] <component...>
       cxbuild all
       cxbuild app graphql
EOF
  echo -e "\nComponents: $(list_components)"
  exit 0
}

declare -a components=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    -*) echo "Unknown option: $1" >&2; exit 1 ;;
    *) components+=("$1"); shift ;;
  esac
done

require_project_root
acquire_lock "build"

mapfile -t all_components < <("$SCRIPT_DIR/cxconfig" components)

if [[ ${#components[@]} -eq 0 ]]; then
  err_msg "Specify components or use 'all'"
  echo "Available: ${all_components[*]}" >&2
  exit 1
fi

expand_components components all_components

project_root=$("$SCRIPT_DIR/cxconfig" root)

build_components "$project_root" "${components[@]}" || {
  err_msg "Build failed"
  exit 1
}

echo
echo "Built $(IFS=', '; echo "${components[*]}") - $(timer_elapsed)"
