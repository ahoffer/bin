#!/usr/bin/env bash
set -euo pipefail

# Build component Docker images
#
# This script ONLY builds images. It does NOT push or deploy.
# After building, use cxdeploy to push images and restart pods.
# Must be run from within a project directory (walks up to find pom.xml).
#
# Usage: cxbuild [options] <component...>
#        cxbuild all
#        cxbuild app graphql
#
# Examples:
#   cxbuild graphql
#   cxbuild all

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
source "$SCRIPT_DIR/cx.lib"
timer_start

usage() {
  cat <<'EOF'
Build component Docker images

This script ONLY builds images. It does NOT push or deploy.
After building, use cxdeploy to push images and restart pods.

Usage: cxbuild [options] <component...>
       cxbuild all
       cxbuild app graphql
EOF
  echo -e "\nComponents: $(list_components)"
  exit 0
}

build_docs_component() {
  local project_root="$1"
  local version
  version=$("$SCRIPT_DIR/cxconfig" version)
  local log_file
  log_file=$(logfile cxbuild "docs")
  run_logged "docs" "$log_file" \
    bash -c '
      set -e
      cd "$1"
      mvn -q install:install-file \
        -Dfile=docs/pom.xml \
        -DpomFile=docs/pom.xml \
        -DgroupId=com.octoconsulting \
        -DartifactId=docs \
        -Dversion="$2" \
        -Dpackaging=pom
      mvn install -pl docker/docs -DskipTests -T6
    ' _ "$project_root" "$version"
}

declare -a components=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    -*) echo "Unknown option: $1" >&2; exit 1 ;;
    *) components+=("$1"); shift ;;
  esac
done

require_project_root
acquire_lock "build"

load_and_expand_components components

project_root=$("$SCRIPT_DIR/cxconfig" root)

declare -a image_components=()
build_docs=""
for component in "${components[@]}"; do
  if [[ "$component" == "docs" ]]; then
    build_docs=1
  else
    image_components+=("$component")
  fi
done

if [[ ${#image_components[@]} -gt 0 ]]; then
  build_components "$project_root" "${image_components[@]}" || {
    err_msg "Build failed"
    exit 1
  }
fi

if [[ -n "${build_docs:-}" ]]; then
  build_docs_component "$project_root" || {
    err_msg "Build failed"
    exit 1
  }
fi

if [[ ${#image_components[@]} -eq 0 && -z "${build_docs:-}" ]]; then
  err_msg "Build failed"
  exit 1
fi

echo
echo "Built $(format_components "${components[@]}") - $(timer_elapsed)"
