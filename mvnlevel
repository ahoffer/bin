#!/usr/bin/env perl
use strict;
use warnings;

$| = 1;

# Gates timestamped Maven log lines by severity level.
# Reads MVNFILTER_LEVEL from the environment (default 3). Invalid values fall back to 3.
# Input format after mvntrim: TIMESTAMP LEVEL message.
#
# Level gate:
#   0  silent
#   1  ERROR only (maximally clean)
#   2  WARNING and ERROR (maximally clean)
#   3  INFO, WARNING, ERROR with plugin goal banners suppressed (default)
#   4  all levels including DEBUG; plugin goal banners pass through
#   5  raw bypass, handled upstream in qb; mvnlevel passes all through
#   9  backward-compat alias for 5

my $raw_level = $ENV{MVNFILTER_LEVEL} // '3';
my $level = ($raw_level =~ /^[0-9]$/) ? int($raw_level) : 3;
$level = 5 if $level == 9;
$level = 3 unless $level >= 0 && $level <= 5;

while (my $line = <STDIN>) {
    if ($level == 0) {
        next;
    } elsif ($level >= 4) {
        print $line;
    } elsif ($level == 3) {
        next if $line =~ /^\S+ INFO ---/;
        print $line;
    } elsif ($level == 2) {
        next if $line =~ /^\S+ INFO /;
        print $line;
    } elsif ($level == 1) {
        next if $line =~ /^\S+ INFO /;
        next if $line =~ /^\S+ WARNING /;
        print $line;
    }
}
