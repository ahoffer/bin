#!/usr/bin/env python3
"""Live GPU monitor with utilization bars, process list, and sparkline."""

import shutil
import sys
import os
import re
import subprocess
import time
from collections import deque

try:
    from rich.live import Live
    from rich.padding import Padding
    from rich.table import Table
    from rich.console import Group
    from rich.text import Text
except ImportError:
    print("rich library not found. Install it with: pip install rich", file=sys.stderr)
    sys.exit(1)

SPARK = "▁▂▃▄▅▆▇█"
REFRESH = 2
HISTORY_LEN = 30


def check_nvidia_smi():
    """Verify nvidia-smi is available and working."""
    if not shutil.which("nvidia-smi"):
        print("nvidia-smi not found. Is the NVIDIA driver installed?", file=sys.stderr)
        sys.exit(1)
    try:
        subprocess.run(
            ["nvidia-smi", "--query-gpu=name", "--format=csv,noheader"],
            capture_output=True,
            check=True,
        )
    except subprocess.CalledProcessError as e:
        msg = (e.stdout or e.stderr or b"").decode().strip() or "unknown error"
        print(f"nvidia-smi failed: {msg}", file=sys.stderr)
        sys.exit(1)


def util_color(pct):
    if pct < 50:
        return "green"
    if pct <= 80:
        return "yellow"
    return "red"


def bar(pct, width=20):
    filled = round(pct / 100 * width)
    color = util_color(pct)
    t = Text()
    t.append("█" * filled, style=color)
    t.append("░" * (width - filled), style="bright_black")
    return t


def sparkline(history):
    t = Text()
    for val in history:
        idx = min(int(val / 100 * len(SPARK)), len(SPARK) - 1)
        t.append(SPARK[idx], style=util_color(val))
    return t


def query_gpu():
    """Query GPU stats. Returns None on error."""
    fields = "name,temperature.gpu,power.draw,power.limit,utilization.gpu,memory.used,memory.total"
    try:
        out = subprocess.check_output(
            ["nvidia-smi", f"--query-gpu={fields}", "--format=csv,noheader,nounits"],
            text=True,
            stderr=subprocess.DEVNULL,
        )
    except subprocess.CalledProcessError:
        return None
    parts = [p.strip() for p in out.strip().split(",")]
    if len(parts) < 7:
        return None
    try:
        return {
            "name": parts[0],
            "temp": int(parts[1]),
            "power": float(parts[2]),
            "power_cap": float(parts[3]),
            "gpu_pct": int(parts[4]),
            "mem_used": int(parts[5]),
            "mem_total": int(parts[6]),
        }
    except (ValueError, IndexError):
        return None


def proc_cmdline(pid):
    """Read executable name from /proc."""
    try:
        raw = open(f"/proc/{pid}/cmdline", "rb").read()
        if raw:
            # Extract first argument and return basename only
            argv0 = raw.split(b"\x00")[0].decode("utf-8", errors="replace")
            return os.path.basename(argv0)
    except (FileNotFoundError, PermissionError):
        pass
    return None


def proc_owner(pid):
    """Read process owner from /proc status."""
    try:
        import pwd
        uid = os.stat(f"/proc/{pid}").st_uid
        return pwd.getpwuid(uid).pw_name
    except (FileNotFoundError, PermissionError, KeyError):
        return "?"


def query_processes():
    """Query GPU processes. Returns empty list on error."""
    try:
        out = subprocess.check_output(
            ["nvidia-smi"], text=True, stderr=subprocess.DEVNULL
        )
    except subprocess.CalledProcessError:
        return []
    procs = []
    for m in re.finditer(
        r"^\|\s+\d+\s+N/A\s+N/A\s+(\d+)\s+(\S+)\s+(.+?)\s+(\d+)MiB\s*\|$",
        out,
        re.MULTILINE,
    ):
        pid = int(m.group(1))
        fallback = os.path.basename(m.group(3).strip())
        cmdline = proc_cmdline(pid) or fallback
        procs.append({
            "pid": pid,
            "type": m.group(2),
            "user": proc_owner(pid),
            "cmd": cmdline,
            "mem_mib": int(m.group(4)),
        })
    return procs


def proc_table(procs):
    tbl = Table(
        show_header=True, show_edge=False, show_lines=False,
        pad_edge=False, padding=(0, 1), box=None,
    )
    tbl.add_column("PID", justify="right", style="cyan", header_style="cyan")
    tbl.add_column("User", style="magenta", header_style="cyan")
    tbl.add_column("VRAM", justify="right", style="cyan", header_style="cyan")
    tbl.add_column("Command", header_style="cyan", max_width=30, no_wrap=True)
    for p in sorted(procs, key=lambda p: p["mem_mib"], reverse=True):
        mem = f"{p['mem_mib'] / 1024:.1f} GB" if p["mem_mib"] > 99 else f"{p['mem_mib']} MB"
        tbl.add_row(str(p["pid"]), p["user"], mem, p["cmd"])
    return tbl


def render(gpu, procs, history):
    mem_pct = gpu["mem_used"] / gpu["mem_total"] * 100
    mem_gb_used = gpu["mem_used"] / 1024
    mem_gb_total = gpu["mem_total"] / 1024
    power = round(gpu["power"])

    # Strip common prefixes from GPU name
    name = gpu['name']
    for prefix in ["NVIDIA GeForce ", "NVIDIA "]:
        if name.startswith(prefix):
            name = name[len(prefix):]
            break

    top = Text()
    top.append(f" {name}", style="bold cyan")
    top.append(f"  {gpu['temp']}°C", style="cyan")
    top.append(f"  {power}W\n\n", style="cyan")
    top.append(" GPU ", style="cyan")
    top.append_text(bar(gpu["gpu_pct"]))
    top.append(f" {gpu['gpu_pct']}%\n", style=util_color(gpu["gpu_pct"]))
    top.append(" MEM ", style="cyan")
    top.append_text(bar(mem_pct))
    top.append(f" {mem_gb_used:.1f}G\n", style=util_color(mem_pct))

    bottom = Text()
    bottom.append(" UTL ", style="cyan")
    bottom.append_text(sparkline(history))

    if procs:
        return Group(top, Padding(proc_table(procs), (0, 0, 0, 2)), Text(), bottom)
    return Group(top, Text("  no GPU processes", style="bright_black"), Text(), bottom)


def main():
    check_nvidia_smi()
    history = deque(maxlen=HISTORY_LEN)
    last_gpu = None
    try:
        with Live(Text("loading..."), refresh_per_second=1, screen=True) as live:
            while True:
                gpu = query_gpu()
                if gpu is None:
                    live.update(Text("  waiting for GPU...", style="yellow"))
                    time.sleep(REFRESH)
                    continue
                last_gpu = gpu
                procs = query_processes()
                history.append(gpu["gpu_pct"])
                live.update(render(gpu, procs, history))
                time.sleep(REFRESH)
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
