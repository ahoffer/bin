#!/usr/bin/env bash
set -uo pipefail  # no -e: continue on errors, report all at end

# Build and deploy components
#
# Builds all components with a single maven invocation, then deploys
# each component in parallel.
# Must be run from within a project directory (walks up to find pom.xml).
#
# Usage: cxship [options] <component...>
#        cxship all
#        cxship app graphql
#
# Options:
#   -r, --remote HOST   Target host (default: from kubectl context)
#   -n, --namespace NS  Kubernetes namespace (default: auto from project)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
source "$SCRIPT_DIR/cx.lib"
timer_start

usage() {
  cat <<'EOF'
Build and deploy components

Builds all components with a single maven invocation, then deploys
each component in parallel.

Usage: cxship [options] <component...>
       cxship all
       cxship app graphql

Options:
  -r, --remote HOST   Target host (default: from kubectl context)
  -n, --namespace NS  Kubernetes namespace (default: auto from project)
EOF
  echo -e "\nComponents: $(list_components)"
  exit 0
}

require_optarg() {
  local opt="$1"
  if [[ $# -lt 2 || -z "${2:-}" || "${2:0:1}" == "-" ]]; then
    err_msg "Option $opt requires a value"
    exit 1
  fi
}

remote_host=""
namespace=""
declare -a components=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    -r|--remote) require_optarg "$1" "${2:-}"; remote_host="$2"; shift 2 ;;
    -n|--namespace) require_optarg "$1" "${2:-}"; namespace="$2"; shift 2 ;;
    -*) echo "Unknown option: $1" >&2; exit 1 ;;
    *) components+=("$1"); shift ;;
  esac
done

[[ -z "$remote_host" ]] && remote_host=$(resolve_default_host)

require_project_root
acquire_lock "builddeploy"

[[ -z "$namespace" ]] && namespace=$("$SCRIPT_DIR/cxconfig" namespace)

mapfile -t all_components < <("$SCRIPT_DIR/cxconfig" components)

if [[ ${#components[@]} -eq 0 ]]; then
  err_msg "Specify components or use 'all'"
  echo "Available: ${all_components[*]}" >&2
  exit 1
fi

expand_components components all_components

project_root=$("$SCRIPT_DIR/cxconfig" root)

# Phase 1: Build all components
build_components "$project_root" "${components[@]}" || {
  err_msg "Build failed, aborting"
  run_completion_hook cxship failure
  exit 1
}

# Phase 2: Deploy in parallel
_deploy_one() {
  deploy_component "$1" "$remote_host" "$namespace"
}
run_parallel _deploy_one components

echo
if [[ ${#parallel_failures[@]} -eq 0 ]]; then
  echo "Shipped $(format_components "${components[@]}") - $(timer_elapsed)"
  run_completion_hook cxship success
else
  echo "Failed $(format_components "${parallel_failures[@]}") - $(timer_elapsed)"
  run_completion_hook cxship failure
  exit 1
fi
