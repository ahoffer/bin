#!/usr/bin/env bash
set -euo pipefail

# Verify all pods in a deployment are running the expected image
# Usage: kverify [-q] [-n namespace] [-r host] [-t timeout] <image:tag> <deployment>
# Examples:
#   kverify myapp:1.0 cx-app                      Verify pods match image
#   kverify -n prod myapp:1.0 cx-app              Specific namespace
#   kverify -r node1 -t 120 myapp:1.0 cx-app      Custom host and timeout

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
source "$SCRIPT_DIR/lib.sh"

usage() {
  sed -n '4,8p' "$0"
  exit 0
}

namespace=""
host=""
timeout=60
interval=2
quiet=false
while [[ $# -gt 0 && "$1" == -* ]]; do
  case "$1" in
    -h|--help) usage ;;
    -q|--quiet) quiet=true; shift ;;
    -n|--namespace) require_optarg "$1" "${2:-}"; namespace="$2"; shift 2 ;;
    -r|--remote) require_optarg "$1" "${2:-}"; host="$2"; shift 2 ;;
    -t|--timeout) require_optarg "$1" "${2:-}"; timeout="$2"; shift 2 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

readonly IMAGE="${1:?Usage: kverify [-n ns] [-r host] [-t timeout] <image:tag> <deployment>}"
readonly DEPLOY="${2:?Usage: kverify [-n ns] [-r host] [-t timeout] <image:tag> <deployment>}"

[[ -z "$host" ]] && host=$(resolve_host)
require_host "$host" || exit 1

require_namespace namespace

readonly NAMESPACE="$namespace"
readonly REMOTE_HOST="$host"
readonly RETRY_TIMEOUT="$timeout"
readonly RETRY_INTERVAL="$interval"

get_pod_selector() {
  kubectl get deployment "$DEPLOY" -n "$NAMESPACE" \
    -o json |
    jq -r '
      [
        (.spec.selector.matchLabels // {} | to_entries[] | "\(.key)=\(.value)"),
        (
          .spec.selector.matchExpressions // [] | .[] |
          if .operator == "In" then
            "\(.key) in (\(.values | join(",")))"
          elif .operator == "NotIn" then
            "\(.key) notin (\(.values | join(",")))"
          elif .operator == "Exists" then
            .key
          elif .operator == "DoesNotExist" then
            "!\(.key)"
          else
            error("unsupported selector operator: \(.operator)")
          end
        )
      ] | join(",")
    '
}

# Check for pod failure states that indicate deployment will not succeed.
# Iterates all containers per pod so sidecar failures are also caught.
check_pod_failures() {
  local selector="$1"
  local fatal_reasons="CrashLoopBackOff|ImagePullBackOff|ErrImagePull|CreateContainerConfigError|InvalidImageName"

  while read -r pod_name reason; do
    [[ -z "$pod_name" || -z "$reason" ]] && continue
    if [[ "$reason" =~ ^($fatal_reasons)$ ]]; then
      echo "ERROR: Pod $pod_name has container in $reason state" >&2
      kubectl describe pod "$pod_name" -n "$NAMESPACE" | tail -20 >&2
      return 1
    fi
  done < <(kubectl get pod -n "$NAMESPACE" -l "$selector" -o json | \
    jq -r '.items[] | .metadata.name as $pod |
      .status.containerStatuses[]? | select(.state.waiting.reason) |
      "\($pod) \(.state.waiting.reason)"')

  return 0
}

# Verify each pod is running the expected image hash.
verify_pod_images() {
  local expected="$1" selector="$2" container="$3" result=0

  while read -r pod_name pod_hash; do
    [[ -z "$pod_name" ]] && continue
    if [[ "$pod_hash" == "$expected" ]]; then
      echo "ok $pod_name"
    else
      printf "MISMATCH %s\n  got:      %s\n  expected: %s\n" "$pod_name" "$pod_hash" "$expected"
      result=1
    fi
  done < <(kubectl get pod -n "$NAMESPACE" -l "$selector" -o json | \
    jq -r --arg cn "$container" '.items[] | .metadata.name as $pod |
      .status.containerStatuses[]? | select(.name == $cn) |
      "\($pod) \(.imageID)"')

  return "$result"
}

$quiet || echo -n "    Verifying..."

crictl=$(crictl_cmd)
EXPECTED_HASH=$(remote_exec "$REMOTE_HOST" "$crictl inspecti '$IMAGE' 2>/dev/null" | jq -r '.status.id')
: "${EXPECTED_HASH:?ERROR: Could not get image hash for $IMAGE}"

SELECTOR=$(get_pod_selector)

# Resolve which container in the deployment uses IMAGE
CONTAINER_NAME=$(kubectl get deployment "$DEPLOY" -n "$NAMESPACE" -o json | \
  jq -r --arg img "$IMAGE" '.spec.template.spec.containers[] | select(.image == $img) | .name')
: "${CONTAINER_NAME:?ERROR: No container in deployment $DEPLOY uses image $IMAGE}"

SECONDS=0

while ! output=$(verify_pod_images "$EXPECTED_HASH" "$SELECTOR" "$CONTAINER_NAME"); do
  if ((SECONDS >= RETRY_TIMEOUT)); then
    $quiet || printf "\r    Verify: FAILED%-54s\n" ""
    echo "$output"
    echo "ERROR: Image verification failed after ${RETRY_TIMEOUT}s" >&2
    exit 1
  fi
  check_pod_failures "$SELECTOR" || exit 1
  $quiet || printf "\r    Verifying... %ds" "$SECONDS"
  sleep "$RETRY_INTERVAL"
done

$quiet || printf "\r    Verified %-58s\n" ""
