#!/usr/bin/env bash
set -euo pipefail

# Probe all xpra displays. Restart the matching service if a probe fails or hangs.
# Format: "display-number/service-name". Add a line here when a new session is introduced.
sessions=("100/xpra-chrome" "101/xpra-signal")

for entry in "${sessions[@]}"; do
    display=":${entry%%/*}"
    service="${entry##*/}"

    if ! timeout 10 xpra info "$display" >/dev/null 2>&1; then
        echo "xpra-healthcheck: probe failed for $display, restarting $service" >&2
        systemctl --user reset-failed "$service" 2>/dev/null || true
        systemctl --user start "$service"
    fi
done
