#!/usr/bin/env bash
#
# Find Here
#
# Search for files in the current directory and subdirectories using case-insensitive
# pattern matching. Suppresses permission denied errors.

# Always ensure pattern has leading and trailing wildcards for substring matching
pattern="${1}"
if [[ "${pattern}" != \** ]]; then
  pattern="*${pattern}"
fi
if [[ "${pattern}" != *\* ]]; then
  pattern="${pattern}*"
fi

uname_s="$(uname -s)"

if command -v fd >/dev/null 2>&1; then
  fd -i -g --no-ignore "${pattern}"
elif command -v fdfind >/dev/null 2>&1; then
  fdfind -i -g --no-ignore "${pattern}"
elif [[ "${uname_s}" == "Darwin" ]]; then
  echo "fd not found. Install it with: brew install fd" >&2
  exit 1
else
  echo "fdfind not found. Using find. Install it with: sudo apt install fd-find" >&2
  find . -iname "${pattern}" 2>/dev/null
fi
