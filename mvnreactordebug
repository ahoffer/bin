#!/usr/bin/env perl
use strict;
use warnings;

# Downgrade Maven reactor summary chatter so it does not crowd the normal
# INFO stream while still remaining available at DEBUG level.

$| = 1;
my $in_summary = 0;

while (my $line = <STDIN>) {
    if ($line =~ /^(\S+\s+)INFO(\s+Reactor Summary for .*)$/) {
        $line = $1 . 'DEBUG' . $2 . "\n";
        $in_summary = 1;
        print $line;
        next;
    }

    if ($in_summary) {
        if ($line =~ /^\S+ INFO (?:BUILD SUCCESS|BUILD FAILURE|Total time:|Finished at:|Final Memory:)/) {
            $in_summary = 0;
            print $line;
            next;
        }

        if ($line =~ /^(\S+\s+)INFO(\s+.+?(?:\s+(?:SUCCESS|FAILURE|SKIPPED)\s+\[.*\])?)$/) {
            $line = $1 . 'DEBUG' . $2 . "\n";
            print $line;
            next;
        }

        $in_summary = 0;
    }

    print $line;
}
