#!/usr/bin/env bash
set -euo pipefail

# Push component images to a k8s host
#
# Must be run from within a project directory (walks up to find pom.xml).
# Uses prebuilt tarballs from docker/<component>/target/image.tar when
# available, otherwise falls back to docker save.
#
# Usage: cxpush [options] <component...>
#        cxpush all
#        cxpush app graphql
#
# Options:
#   -r, --remote HOST   Target host (default: CX_HOST or clown)

source cx.lib
timer_start

usage() {
  cat <<'EOF'
Push component images to a k8s host

Uses prebuilt tarballs from docker/<component>/target/image.tar when
available, otherwise falls back to docker save.

Usage: cxpush [options] <component...>
       cxpush all
       cxpush app graphql

Options:
  -r, --remote HOST   Target host (default: CX_HOST or clown)
EOF
  echo -e "\nComponents: $(list_components)"
  exit 0
}

remote_host=""
declare -a components=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    -r|--remote) remote_host="$2"; shift 2 ;;
    -*) echo "Unknown option: $1" >&2; exit 1 ;;
    *) components+=("$1"); shift ;;
  esac
done

[[ -z "$remote_host" ]] && remote_host=$(resolve_default_host)

require_project_root
acquire_lock "push"

mapfile -t all_components < <(cxconfig components)

if [[ ${#components[@]} -eq 0 ]]; then
  err_msg "Specify components or use 'all'"
  echo "Available: ${all_components[*]}" >&2
  exit 1
fi

expand_components components all_components

_push_one() {
  push_component "$1" "$remote_host"
}
run_parallel _push_one components

echo
if [[ ${#parallel_failures[@]} -eq 0 ]]; then
  echo "Pushed $(IFS=', '; echo "${components[*]}") - $(timer_elapsed)"
else
  echo "Failed $(IFS=', '; echo "${parallel_failures[*]}") - $(timer_elapsed)"
  exit 1
fi
