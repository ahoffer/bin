#!/bin/bash
# Add a domain to the PAC proxy list

if [ -z "$1" ]; then
  echo "Usage: proxyadd <domain>"
  echo "Example: proxyadd example.com"
  exit 1
fi

DOMAIN="$1"
PAC_FILE="$HOME/Library/WebServer/proxy.pac"

if grep -q "\"$DOMAIN\"" "$PAC_FILE"; then
  echo "Domain '$DOMAIN' is already in the proxy list"
  exit 0
fi

# Find the last domain entry and add the new one after it
sed -i.bak "/\"oaistatic.com\"/a\\
    \"$DOMAIN\",
" "$PAC_FILE"

# Clean up the formatting (remove extra comma if it's now the last entry)
# This is a simple approach; adjust if needed

echo "Added '$DOMAIN' to proxy list"
echo ""
echo "Current domains:"
grep -o '"[^"]*"' "$PAC_FILE" | head -20

echo ""
echo "Note: Chrome must be restarted to pick up the change"
echo "Run: pkill -i chrome && chrome"
