#!/usr/bin/env bash
set -euo pipefail

HOST="bigfish"
PORT="14501"

# Assumes SSH key auth is configured so `ssh ${HOST}` does not prompt.
# Bail out quietly if host is unreachable (prevents launchd restart loops)
if ! nc -z -w 2 "${HOST}" 22 >/dev/null 2>&1; then
  exit 0
fi

# Ensure tunnel is up (reuse if already present)
if ! lsof -nP -iTCP:${PORT} -sTCP:LISTEN >/dev/null 2>&1; then
  ssh -o ConnectTimeout=5 -N -f -L ${PORT}:127.0.0.1:${PORT} ${HOST} || exit 0
fi

# For debugging, run the binary directly to see logs:
# /Applications/Xpra.app/Contents/MacOS/Xpra attach tcp://127.0.0.1:${PORT}
open -a "Xpra" --args attach "tcp://127.0.0.1:${PORT}" >/dev/null 2>&1
