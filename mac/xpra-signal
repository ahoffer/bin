#!/usr/bin/env bash
set -euo pipefail

HOST="bigfish"
PORT="14502"
# Dedicated control socket keeps this tunnel isolated from shared SSH masters.
CONTROL_PATH="${HOME}/.ssh/cm-xpra-${HOST}-${PORT}"

# Attaches the local macOS Xpra.app client to the long-lived xpra server on bigfish.
# The remote X11 display :101 hosts the Signal Desktop session.
# Verify the active display on bigfish with:
#   xpra list
#   DISPLAY=:101 xdpyinfo | head

# Assumes SSH key auth is configured so ssh bigfish does not prompt.
# Bail out quietly if host is unreachable, prevents launchd restart loops.
if ! ssh -o ConnectTimeout=3 -o BatchMode=yes -o ControlMaster=no "${HOST}" true 2>/dev/null; then
  exit 0
fi

# Already connected on this port, nothing to do.
if lsof -nP -iTCP:"${PORT}" -sTCP:ESTABLISHED 2>/dev/null | awk '$1=="Xpra" {found=1} END {exit !found}'; then
    exit 0
fi

# Ensure tunnel is up, reuse if already present.
if ! lsof -nP -iTCP:${PORT} -sTCP:LISTEN >/dev/null 2>&1; then
  mkdir -p "${HOME}/.ssh"
  # Force a per-port master so watchdog cleanup can target only this tunnel.
  ssh \
    -o ConnectTimeout=5 \
    -o ExitOnForwardFailure=yes \
    -o ControlMaster=yes \
    -o ControlPath="${CONTROL_PATH}" \
    -o ControlPersist=no \
    -N -f -L ${PORT}:127.0.0.1:${PORT} ${HOST} || exit 0
fi

LOG="$HOME/Library/Logs/xpra-signal.log"
for i in 6 5 4 3 2 1; do
  [ -f "${LOG}.${i}" ] && mv "${LOG}.${i}" "${LOG}.$((i+1))"
done
[ -f "$LOG" ] && mv "$LOG" "${LOG}.1"
nohup /Applications/Xpra.app/Contents/MacOS/Xpra attach "tcp://127.0.0.1:${PORT}" \
  >"$LOG" 2>&1 &
# Detach from bash job table so bash does not emit job-death messages to stderr
# when this script is called as a subprocess (e.g., from the healthcheck).
disown
