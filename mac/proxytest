#!/bin/bash
# Test SOCKS proxy connectivity

echo "=== Testing SOCKS Proxy ==="
echo ""

echo "1. Testing proxy port accessibility..."
if lsof -i :1080 >/dev/null 2>&1; then
  echo "   ✓ Port 1080 is listening"
else
  echo "   ✗ Port 1080 is NOT listening"
  exit 1
fi

echo ""
echo "2. Testing connection through proxy to slack.com..."
if curl --socks5-hostname 127.0.0.1:1080 https://slack.com -I --connect-timeout 10 2>&1 | grep -q "HTTP/"; then
  echo "   ✓ Successfully connected to slack.com"
else
  echo "   ✗ Failed to connect to slack.com"
  exit 1
fi

echo ""
echo "3. Testing connection through proxy to gmail.com..."
if curl --socks5-hostname 127.0.0.1:1080 https://gmail.com -I --connect-timeout 10 2>&1 | grep -q "HTTP/"; then
  echo "   ✓ Successfully connected to gmail.com"
else
  echo "   ✗ Failed to connect to gmail.com"
  exit 1
fi

echo ""
echo "4. Testing direct connection (no proxy)..."
if curl https://example.com -I --connect-timeout 10 2>&1 | grep -q "HTTP/"; then
  echo "   ✓ Direct connection works"
else
  echo "   ✗ Direct connection failed"
  exit 1
fi

echo ""
echo "All tests passed!"
