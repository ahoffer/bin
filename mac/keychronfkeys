#!/bin/bash
# Remap Keychron V6 vendor function keys to standard F3-F6.
# macOS handles apple_vendor_keyboard_key_codes before Karabiner can intercept
# them, so this must be done at the hidutil level.
#
# F3: mission_control (0xFF010010) -> F3 (0x0007003C)
# F4: spotlight       (0xFF010001) -> F4 (0x0007003D)
# F5: dictation       (0x000C00CF) -> F5 (0x0007003E)
# F6: do_not_disturb  (0x0001009B) -> F6 (0x0007003F)
hidutil property \
    --matching '{"VendorID":0x3434,"ProductID":0x0361}' \
    --set '{"UserKeyMapping":[
        {"HIDKeyboardModifierMappingSrc":0xFF010010,"HIDKeyboardModifierMappingDst":0x0007003C},
        {"HIDKeyboardModifierMappingSrc":0xFF010001,"HIDKeyboardModifierMappingDst":0x0007003D},
        {"HIDKeyboardModifierMappingSrc":0x000C00CF,"HIDKeyboardModifierMappingDst":0x0007003E},
        {"HIDKeyboardModifierMappingSrc":0x0001009B,"HIDKeyboardModifierMappingDst":0x0007003F}
    ]}'
