#!/bin/bash
# Check status of SOCKS proxy and PAC server

echo "=== Proxy Services Status ==="
echo ""

echo "SOCKS Proxy (port 1080):"
if launchctl list | grep -q com.aaron.socksproxy; then
  PID=$(launchctl list | grep com.aaron.socksproxy | awk '{print $1}')
  if [ "$PID" = "-" ]; then
    echo "  Status: LOADED but NOT RUNNING"
  else
    echo "  Status: RUNNING (PID: $PID)"
    if lsof -i :1080 >/dev/null 2>&1; then
      echo "  Port 1080: LISTENING"
      CONNS=$(lsof -i :1080 2>/dev/null | grep ESTABLISHED | wc -l | tr -d ' ')
      echo "  Active connections: $CONNS"
    else
      echo "  Port 1080: NOT LISTENING"
    fi
  fi
else
  echo "  Status: NOT LOADED"
fi

echo ""
echo "PAC Server (port 8888):"
if launchctl list | grep -q com.aaron.pacserver; then
  PID=$(launchctl list | grep com.aaron.pacserver | awk '{print $1}')
  if [ "$PID" = "-" ]; then
    echo "  Status: LOADED but NOT RUNNING"
  else
    echo "  Status: RUNNING (PID: $PID)"
    if curl -s http://127.0.0.1:8888/proxy.pac >/dev/null 2>&1; then
      echo "  PAC file: ACCESSIBLE"
    else
      echo "  PAC file: NOT ACCESSIBLE"
    fi
  fi
else
  echo "  Status: NOT LOADED"
fi

echo ""
echo "SSH Tunnel:"
if ps aux | grep -v grep | grep "ssh.*bigfish" | grep -q "D 1080"; then
  echo "  Status: CONNECTED to bigfish"
else
  echo "  Status: NOT CONNECTED"
fi

echo ""
echo "Logs:"
echo "  SOCKS: /tmp/socksproxy.err"
echo "  PAC:   /tmp/pacserver.err"
