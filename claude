#!/usr/bin/env bash
set -euo pipefail

realClaude="$(PATH="${PATH//$HOME\/bin:/}" command -v claude 2>/dev/null || echo "")"
if [[ -z "$realClaude" ]]; then
    echo "error: claude not found outside ~/bin" >&2
    exit 1
fi

sessionName="claude"

if [[ -n "${TMUX:-}" ]]; then
    exec wraplog "claude" "$realClaude" "$@"
fi

if tmux has-session -t "$sessionName" 2>/dev/null; then
    exec tmux attach-session -t "$sessionName"
else
    exec tmux new-session -s "$sessionName" -- "$0" "$@"
fi
