#!/usr/bin/env bash
set -euo pipefail

# Strip ~/bin so command -v finds the real binary, not this wrapper.
realClaude="$(PATH="$(tr ':' '\n' <<< "$PATH" | grep -vxF "$HOME/bin" | tr '\n' ':' | sed 's/:$//')" \
    command -v claude 2>/dev/null || echo "")"
if [[ -z "$realClaude" ]]; then
    echo "error: claude not found outside ~/bin" >&2
    exit 1
fi

exec wraplog "claude" "$realClaude" "$@"
