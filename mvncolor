#!/usr/bin/env perl
use strict;
use warnings;

# Applies ANSI colors to filtered Maven output. Skips colorization when
# stdout is not a terminal so piped output stays clean.
# Input format after mvntrim: TIMESTAMP LEVEL message.

$| = 1;

my $tty = -t STDOUT;

while (my $line = <STDIN>) {
    unless ($tty) {
        print $line;
        next;
    }

    (my $out = $line) =~ s/\n$/\e[0m\n/;

    if    ($line =~ /^\S+ ERROR /)              { print "\e[31m$out"   }
    elsif ($line =~ /^\S+ WARNING /)            { print "\e[33m$out"   }
    elsif ($line =~ /^\S+ DEBUG /)              { print "\e[2m$out"    }
    elsif ($line =~ /^\S+ INFO BUILD SUCCESS/)  { print "\e[1;32m$out" }
    elsif ($line =~ /^\S+ INFO BUILD FAILURE/)  { print "\e[1;31m$out" }
    elsif ($line =~ /^\S+ INFO Building /)      { print "\e[1;36m$out" }
    elsif ($line =~ /^\S+ INFO BUILT /)         { print "\e[36m$out"   }
    elsif ($line =~ /^\S+ INFO Reactor Sum/)    { print "\e[1m$out"    }
    else                                        { print $line          }
}
