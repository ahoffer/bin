#!/usr/bin/env perl
use strict;
use warnings;

# Assigns a distinct color to each severity level so the eye can locate errors
# and warnings without parsing the level token. The TTY check skips colorization
# when stdout is not a terminal, keeping escape codes out of log files and CI
# system output. Input format after mvntrim: TIMESTAMP LEVEL message.

$| = 1;

my $tty = -t STDOUT;

while (my $line = <STDIN>) {
    unless ($tty) {
        print $line;
        next;
    }

    (my $out = $line) =~ s/\n$/\e[0m\n/;

    if    ($line =~ /^\S+ ERROR /)   { print "\e[31m$out" }
    elsif ($line =~ /^\S+ WARNING /) { print "\e[33m$out" }
    elsif ($line =~ /^\S+ DEBUG /)   { print "\e[92m$out" }
    elsif ($line =~ /^\S+ TRACE /)   { print "\e[90m$out" }
    elsif ($line =~ /^\S+ INFO /)    { print "\e[36m$out" }
    else                              { print $line        }
}
