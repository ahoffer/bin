#!/usr/bin/env bash
# Updates JAVA_HOME in ~/javahome and in your current shell.

# 1) Parse installed JDKs from java_home -V stderr
mapfile -t lines < <(
  /usr/libexec/java_home -V 2>&1 \
    | grep -E '^\s+[0-9]+\.' \
    | sed 's/^ *//'
)

if ((${#lines[@]} == 0)); then
  echo "No JDKs found." >&2
  exit 1
fi

# Extract home paths and display info from each line
declare -a homes
i=0
for line in "${lines[@]}"; do
  home="${line##* /}"
  home="/$home"
  version="${line%% (*}"
  vendor=$(echo "$line" | sed 's/.*"\([^"]*\)" - .*/\1/')
  if [[ -x "$home/bin/javac" ]]; then
    tag="JDK"
  elif [[ -x "$home/bin/java" ]]; then
    tag="JRE"
  else
    tag="Unknown"
  fi
  printf "[%d] %s  %s (%s)\n" "$i" "$version" "$vendor" "$tag"
  homes+=("$home")
  ((i++))
done

# 2) Read user's choice
read -rp "Select Java version (0-$((i - 1))): " selection
if ! [[ "$selection" =~ ^[0-9]+$ ]] || ((selection < 0 || selection >= i)); then
  echo "Invalid selection." >&2
  exit 1
fi

selected="${homes[selection]}"
echo "export JAVA_HOME=$selected" > "$HOME/javahome"
export JAVA_HOME="$selected"
echo "JAVA_HOME set to $selected"
