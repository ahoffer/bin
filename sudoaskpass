#!/bin/bash
# Askpass helper for use with SUDO_ASKPASS.
# Shows a native macOS password dialog so the user can approve or deny
# each sudo invocation from non-interactive contexts like Claude Code.

prompt="${1:-Password:}"

exec osascript -e "
  set pw to text returned of (display dialog \"$prompt\" with title \"sudo authorization requested\" default answer \"\" with hidden answer giving up after 60)
  pw
" 2>/dev/null
