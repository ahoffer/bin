#!/usr/bin/env perl
use strict;
use warnings;

$| = 1;

# Filters Maven stdout to strip noise while preserving actionable output.
# Errors, warnings, build success and failure, module progress, and the
# reactor summary all pass through. Suppressed categories: separator lines,
# plugin banners, mojo markers, download progress, per-file formatter and
# license output, lifecycle skipping notices, SCM plugin chatter, pom install
# lines, embedded yarn and Next.js frontend output, reactor plan module list,
# Docker build step and cache lines, assembly copy noise, root-skip notices,
# Maven resume-build hints, and Maven help references (-> [Help N]).
#
# Synthetic lines emitted: BUILT when each module's successor starts,
# Licenses once per module when license activity is detected, FAILED when
# a goal-execution error is detected.
#
# Reactor summary SUCCESS/FAILURE lines are collapsed to the module name,
# with FAILURE lines promoted to ERROR level.
#
# Severity-level filtering (MVNFILTER_LEVEL 0-4) is handled downstream by
# mvnlevel. Set MVNFILTER_LEVEL=9 to bypass all suppression in this script.
#
# Expected-noise lines are demoted from INFO or WARNING to DEBUG or TRACE by
# demote_expected_noise so they are hidden at the default level but visible
# with -v4.

my $lvl_env = $ENV{MVNFILTER_LEVEL} // '';
my $raw_mode = ($lvl_env eq '5' || $lvl_env eq '9');
my $allow_synthetic = (($ENV{MVNFILTER_THREADED} // '0') eq '0');

my $in_reactor_order = 0;
my $last_module_name;     # Most recently started module, for BUILT and Licenses.
my $license_emitted;      # Whether a Licenses line has been emitted for the current module.
my %missing_test_source_seen;   # Deduplicate repeated missing-test-source lines per module.
my %missing_resource_dir_seen;  # Deduplicate repeated missing-resource-directory lines per module.

while (my $line = <STDIN>) {
    normalize(\$line);
    if ($raw_mode) { print $line; next }

    rewrite_expected_noise(\$line);
    demote_expected_noise(\$line);
    next if suppress_reactor_order(\$line);
    next if handle_module_header(\$line);
    next if suppress_duplicate_expected_noise(\$line);
    next if suppress_noise(\$line);
    next if handle_license_activity(\$line);
    next if suppress_docker(\$line);
    next if suppress_assembly(\$line);
    next if suppress_lifecycle(\$line);
    next if suppress_scm(\$line);
    next if suppress_installs(\$line);
    next if suppress_yarn(\$line);
    next if suppress_frontend(\$line);
    next if handle_auth_warning(\$line);
    next if handle_reactor_summary(\$line);
    emit_failed_marker($line);
    print $line;
}

# Strip CRLF, ANSI escape sequences, and Maven help-reference suffixes.
sub normalize {
    my $r = shift;
    $$r =~ s/\r//g;
    $$r =~ s/\e\[[0-9;]*[a-zA-Z]//g;
    $$r =~ s/\s*->\s*\[Help \d+\]\s*(?=\s*$)//;
    # fmt-maven-plugin emits lowercase [info]/[warning]/[error] tags. Normalize
    # them to uppercase so all downstream patterns match consistently.
    $$r =~ s/^\[([a-z]+)\]/sprintf('[%s]', uc($1))/e;
    $$r =~ s/^\[INFO\] (BUILD FAILURE)/[ERROR] $1/;
    $$r =~ s/^\[INFO\] (BUILD SUCCESS)/[WARNING] $1/;
}

# Normalize plugin-grammar quirks so expected-noise lines are readable and
# consistent before level demotion and deduplication logic runs.
sub rewrite_expected_noise {
    my $r = shift;
    $$r =~ s/^\[INFO\] No sources to compile\s*$/[INFO] No sources to compile.\n/;
    $$r =~ s{^\[INFO\] skip non existing resourceDirectory (.+?)\s*$}{[INFO] Skipping nonexistent resource directory: $1\n};
}

# Suppress the Reactor Build Order section that Maven prints at startup.
# The state machine resets on the first blank INFO line; an explicit packaging-
# type regex catches any module lines that slip through before the reset.
sub suppress_reactor_order {
    my $r = shift;
    if ($$r =~ /^\[INFO\] Reactor Build Order:/) { $in_reactor_order = 1; return 1 }
    if ($in_reactor_order) {
        $in_reactor_order = 0 if $$r =~ /^\[INFO\]\s*$/;
        return 1;
    }
    return 1 if $$r =~ /^\[INFO\] .+\s+\[(?:pom|jar|bundle|war|ear|aar|feature|kar|karaf-assembly|zip)\]\s*$/;
    return 1 if $$r =~ /^\[INFO\] Using the MultiThreadedBuilder/;
    return 0;
}

# Normalize module headers: strip artifact coordinates and version, emit a
# synthetic BUILT line for the previous module. This only stays enabled when
# qb is running single-threaded, because multi-threaded output does not give
# enough ordering guarantees to attribute completion correctly.
sub handle_module_header {
    my $r = shift;
    return 0 unless $$r =~ /^\[INFO\] Building (.+) \d+[\d.]*(?:-[A-Za-z0-9]+)*(?:\s+\[(\d+\/\d+)\])?\s*$/;
    my ($module, $progress) = ($1, $2);
    print "[INFO] BUILT $last_module_name\n" if $allow_synthetic && defined $last_module_name;
    print "[INFO] Building $module" . (defined $progress ? " [$progress]" : "") . "\n";
    $last_module_name = $module;
    $license_emitted = undef;
    %missing_test_source_seen = ();
    %missing_resource_dir_seen = ();
    return 1;
}

# Maven plugins can emit the same missing-directory notice multiple times in a
# single module (for example fmt:format and fmt:check). Keep the first line and
# suppress repeats until the next module starts.
sub suppress_duplicate_expected_noise {
    my $r = shift;
    if ($$r =~ /^\[(?:INFO|DEBUG|TRACE)\] (?:Test )?[Ss]ource directory '(.+?)' does not exist\.?\s*$/) {
        my $key = lc $1;
        return 1 if $missing_test_source_seen{$key}++;
        return 0;
    }
    if ($$r =~ /^\[(?:INFO|DEBUG|TRACE)\] Skipping nonexistent resource directory: (.+?)\s*$/) {
        my $key = lc $1;
        return 1 if $missing_resource_dir_seen{$key}++;
        return 0;
    }
    return 0;
}

# Suppress structural noise: separator lines, mojo markers, blank level lines,
# download progress, formatter output, and reactor plan packaging-type lines.
sub suppress_noise {
    my $r = shift;
    my $line = $$r;
    return 1 if $line =~ /^\[INFO\] -{10}/;
    return 1 if $line =~ /^\[INFO\] >>> /;
    return 1 if $line =~ /^\[INFO\] <<< /;
    return 1 if $line =~ /^\[INFO\]\s*$/;
    return 1 if $line =~ /^\[WARNING\]\s*$/;
    return 1 if $line =~ /^\[WARNING\] \*{5,}\s*$/;
    return 1 if $line =~ /^\[WARNING\] .+failed to transfer from .+ during a previous attempt/;
    return 1 if $line =~ /^\[ERROR\]\s*$/;
    return 1 if $line =~ /^\[ERROR\] To see the full stack trace/;
    return 1 if $line =~ /^\[ERROR\] Re-run Maven using the -X switch/;
    return 1 if $line =~ /^\[ERROR\] For more information about the errors/;
    return 1 if $line =~ /^\[ERROR\] The build could not read /;
    return 1 if $line =~ /^\[ERROR\] After correcting the problems,/;
    return 1 if $line =~ /^\[ERROR\] mvn .*-rf /;
    return 1 if $line =~ /^\[INFO\] Downloading from /;
    return 1 if $line =~ /^\[INFO\] Downloaded from /;
    return 1 if $line =~ /^\[INFO\] Scanning for projects/;
    return 1 if $line =~ /^\[INFO\] Updating file header in /;
    return 1 if $line =~ /^\[INFO\] Skipping file header /;
    return 1 if $line =~ /^\[INFO\] Reformatting /;
    return 1 if $line =~ /^\[INFO\] Skipping \//;
    return 0;
}

# Collapse license-header activity to one attributed line per module when
# ordering is trustworthy. In threaded builds, keep suppressing the per-file
# chatter but avoid emitting a guessed module label.
sub handle_license_activity {
    my $r = shift;
    return 0 unless $$r =~ /^\[INFO\] (?:Updating license headers|Checking licenses)/;
    if ($allow_synthetic && defined $last_module_name && !$license_emitted) {
        $license_emitted = 1;
        print "[INFO] Licenses :: $last_module_name\n";
    }
    return 1;
}

# Suppress Docker build step and layer-cache lines; image creation and error
# lines pass through.
sub suppress_docker {
    my $r = shift;
    return 1 if $$r =~ /^\[INFO\] DOCKER> Step \d/;
    return 1 if $$r =~ /^\[INFO\] DOCKER> --->/;
    return 1 if $$r =~ /^\[INFO\] DOCKER>\s*$/;
    return 0;
}

# Suppress assembly descriptor, file-copy, and root-skip notices.
sub suppress_assembly {
    my $r = shift;
    return 1 if $$r =~ /^\[INFO\] Skipping because we are not in root module/;
    return 1 if $$r =~ /^\[INFO\] Reading assembly descriptor:/;
    return 1 if $$r =~ /^\[INFO\] Copying files to /;
    return 0;
}

# Suppress lifecycle skipping notices: formatter packaging check, license
# plugin skip, JaCoCo skip, surefire/failsafe argline placeholder, test skip.
sub suppress_lifecycle {
    my $r = shift;
    return 1 if $$r =~ /^\[INFO\] Skipping format check\b/;
    return 1 if $$r =~ /^\[INFO\] License Plugin is Skipped/;
    return 1 if $$r =~ /^\[INFO\] Skipping JaCoCo execution/;
    return 1 if $$r =~ /^\[INFO\] (?:surefire|failsafe)ArgLine set to empty/;
    return 1 if $$r =~ /^\[INFO\] Test Source directory:/;
    return 1 if $$r =~ /^\[INFO\] Skipping execution\./;
    return 0;
}

# Suppress SCM buildnumber-plugin chatter: git invocation details that do not
# change how a developer reacts to the build result.
sub suppress_scm {
    my $r = shift;
    return 1 if $$r =~ /^\[INFO\] ShortRevision tag detected\./;
    return 1 if $$r =~ /^\[INFO\] Executing: \/bin\/sh/;
    return 1 if $$r =~ /^\[INFO\] Working directory: /;
    return 0;
}

# Suppress pom.xml artifact install lines and context pom.xml references.
sub suppress_installs {
    my $r = shift;
    return 1 if $$r =~ /^\[INFO\] Installing .*pom\.xml /;
    return 1 if $$r =~ /^\[INFO\]\s+from .*pom\.xml/;
    return 0;
}

# Suppress frontend-maven-plugin yarn chatter. These lines bypass the
# standalone yarn filters, so they must be handled here to keep Maven output
# focused on build progress and actual failures instead of repetitive setup,
# version-confirmation, and "everything is fine" boilerplate that does not
# change what a developer should do next.
sub suppress_yarn {
    my $r = shift;
    return 1 if $$r =~ /^\[INFO\] (?:\S+\s+)?YN(?:0000|0002|0007|0008|0013|0060|0086): /;
    return 1 if $$r =~ /^\[INFO\] warning package\.json: No license field\s*$/;
    return 1 if $$r =~ /^\[INFO\] warning No license field\s*$/;
    return 1 if $$r =~ /^\[INFO\] yarn (?:install|run) v/;
    return 1 if $$r =~ /^\[INFO\] \[\d+\/\d+\] /;
    return 1 if $$r =~ /^\[INFO\] \$ yarn /;
    return 1 if $$r =~ /^\[INFO\] Done in \d/;
    return 1 if $$r =~ /^\[INFO\] Node v[\d.]+ is already installed\./;
    return 1 if $$r =~ /^\[INFO\] Yarn .+ was installed, but we need version /;
    return 1 if $$r =~ /^\[INFO\] Installing Yarn version /;
    return 1 if $$r =~ /^\[INFO\] Yarn .+ is installed\./;
    return 1 if $$r =~ /^\[INFO\] Installed Yarn locally\./;
    return 1 if $$r =~ /^\[INFO\] Unpacking .*\/yarn-[\d.]+\.tar\.gz into /;
    return 1 if $$r =~ /^\[INFO\]\s+Node Version Check:\s*$/;
    return 1 if $$r =~ /^\[INFO\]\s+Expected:\s+v[\d.]+ /;
    return 1 if $$r =~ /^\[INFO\]\s+Current:\s+v[\d.]+ /;
    return 1 if $$r =~ /^\[INFO\] Checking formatting\.\.\.\s*$/;
    return 1 if $$r =~ /^\[INFO\] All matched files use Prettier code style!\s*$/;
    return 0;
}

# Suppress the Next.js route table and bundle summary emitted by
# frontend-maven-plugin. These rows are decorative inventory, not actionable
# build signal, so match them by structure instead of exact glyphs to keep the
# filter reliable even when Perl is reading raw UTF-8 bytes.
sub suppress_frontend {
    my $r = shift;
    return 1 if $$r =~ /^\[INFO\] [\x80-\xFF]+(?:\s+[\x80-\xFF]+)?\s+\/\S*/;
    return 1 if $$r =~ /^\[INFO\] Route \(/;
    return 1 if $$r =~ /^\[INFO\] \+ First Load JS/;
    return 1 if $$r =~ /^\[INFO\] [\x80-\xFF]+\s+\/\S*/;
    return 0;
}

# Collapse 401 auth-failure warnings to one short line: status, repo, artifact.
# The redundant "cached failure" duplicate is suppressed by suppress_noise.
sub handle_auth_warning {
    my $r = shift;
    return 0 unless $$r =~ /^\[WARNING\] Could not transfer \S+ (\S+) from\/to (\S+) \(.+\): authentication failed .+, status: (\d+)/;
    print "[WARNING] $3 $2: $1\n";
    return 1;
}

# Collapse reactor summary lines to module name only. SUCCESS stays INFO;
# FAILURE is promoted to ERROR.
sub handle_reactor_summary {
    my $r = shift;
    return 0 unless $$r =~ /^\[INFO\] (.+?)\s+\.{3,}\s+(SUCCESS|FAILURE)\s+\[/;
    my ($module, $outcome) = ($1, $2);
    if ($outcome eq 'SUCCESS') {
        print "[INFO] $module\n";
    } else {
        print "[ERROR] $module\n";
    }
    return 1;
}

# Changes level tag of a line in place when it matches $pat, so the line
# survives to print at the new level rather than being suppressed or kept at
# its original level. Calling this before suppress_* functions means those
# functions will not see the original level tag and will not suppress the line.
sub downgrade {
    my ($r, $new_level, $pat) = @_;
    $$r =~ s/^\[(?:INFO|WARNING|ERROR)\]/[$new_level]/ if $$r =~ $pat;
}

# Reassigns log levels for lines that are structurally expected or not
# immediately actionable so the default INFO view stays focused on real
# milestones and actual problems. Lines demoted to DEBUG appear with -v4;
# lines demoted to TRACE appear with -v4 as well and represent even lower
# signal diagnostics. All patterns match Maven bracket format before
# timestamps are added downstream by mvnts.
#
# This function is called before all suppress_* functions. Demoting a line
# prevents the suppress functions from matching it, which is intentional:
# suppressed lines vanish entirely, but demoted lines remain available for
# diagnosis at higher verbosity levels.
sub demote_expected_noise {
    my $r = shift;

    # Non-Java modules like docs intentionally have no src/main/java or
    # src/test/java. Maven warns about missing source directories every build,
    # but the warnings carry no signal because the absence is structural.
    downgrade($r, 'DEBUG', qr/^\[WARNING\] (?:Test )?[Ss]ource directory '.*' does not exist/);

    # qb-install-docs-artifact creates a detached HEAD clone to build docs,
    # so the license plugin cannot resolve a branch name. The warning fires
    # every docs build and is never a sign of a broken repository.
    # mvnbranchdebug also demotes this in the main pipeline for defense in depth.
    downgrade($r, 'DEBUG', qr/^\[WARNING\] Cannot get the branch information from the git repository/);

    # Antora writes a shared PDF nav file and overwrites it once per module
    # as each module contributes its nav. The overwrite is intentional, so
    # the warning repeats but never indicates a real problem.
    downgrade($r, 'DEBUG', qr/^\[WARNING\] Duplicated destination found: overwriting file:/);

    # Docs module packages content as a ZIP, not a JAR. Maven warns about
    # the empty JAR because it does not know the ZIP is the real artifact.
    downgrade($r, 'DEBUG', qr/^\[WARNING\] JAR will be empty - no content was marked for inclusion/);

    # Docs module produces two ZIP classifiers. Maven warns when the second
    # replaces the first in the build context, but this is the intended layout.
    downgrade($r, 'DEBUG', qr/^\[WARNING\] artifact .+ already attached, replace previous instance/);

    # A build that skips tests looks identical to one that ran and passed them
    # at INFO level. Surfacing this at DEBUG keeps CI output unambiguous about
    # whether test coverage was exercised.
    downgrade($r, 'DEBUG', qr/^\[INFO\] Tests are skipped\./);

    # When a Docker build fails mid-layer, the step number and command in this
    # line are the primary way to identify which Dockerfile instruction failed.
    # Without it the developer must correlate against the Dockerfile manually.
    downgrade($r, 'DEBUG', qr/^\[INFO\] DOCKER> Step \d/);

    # Next.js emits a route table and per-route bundle size after each compile.
    # Keeping these at DEBUG preserves a free bundle-regression signal for CI
    # without flooding the default INFO view during every build.
    downgrade($r, 'DEBUG', qr/^\[INFO\] Route \(/);
    downgrade($r, 'DEBUG', qr/^\[INFO\] \+ First Load JS/);
    downgrade($r, 'DEBUG', qr/^\[INFO\] [\x80-\xFF]+(?:\s+[\x80-\xFF]+)?\s+\/\S*/);
    downgrade($r, 'DEBUG', qr/^\[INFO\] [\x80-\xFF]+\s+\/\S*/);

    # When a POM fails to parse, Maven emits the parse errors and then this
    # line naming the project. Without this line the developer must infer
    # which module is broken from surrounding context rather than reading it.
    downgrade($r, 'DEBUG', qr/^\[ERROR\] The build could not read /);

    # After a build failure Maven prints the exact command to resume from the
    # failing module. Suppressing it forces developers to reconstruct the -rf
    # flag by hand; keeping it at DEBUG means it appears whenever someone runs
    # qb -v4 to investigate a failure.
    downgrade($r, 'DEBUG', qr/^\[ERROR\] mvn .+-rf /);

    # Antora emits one Converted line per document page. At INFO this produces
    # dozens of lines per module; a developer tracking docs build progress
    # only needs to know the module finished, not each individual page.
    downgrade($r, 'DEBUG', qr/^\[INFO\] Converted .+\.adoc/);

    # Maven resource copy counts confirm the plugin ran but do not indicate
    # milestones a developer needs to track. The build result communicates
    # success or failure without these intermediate accounting lines.
    downgrade($r, 'DEBUG', qr/^\[INFO\] Copying \d+ resources? from /);

    # Antora resolves basedir automatically from playbook paths and the value
    # never changes between runs. A developer only needs it when debugging
    # why Antora cannot find a content source.
    downgrade($r, 'DEBUG', qr/^\[INFO\] Highest basedir set to:/);

    # The frontend plugin logs which yarn lifecycle phase it is delegating to.
    # Knowing yarn:validate or yarn:compile ran is only relevant when diagnosing
    # a yarn failure, not during every passing build.
    downgrade($r, 'DEBUG', qr/^\[INFO\] Running 'yarn run maven:/);

    # prettier and cross-env/antora command lines confirm the tool was invoked
    # but add nothing beyond what a tool failure would already report. They are
    # only useful when debugging the tool invocation itself.
    downgrade($r, 'DEBUG', qr/^\[INFO\] \$ (?:prettier|cross-env) /);

    # Non-Java modules have no src/main/resources or src/test/resources by
    # design. Maven notes the absence every build, but it is structural and
    # not a problem to fix.
    downgrade($r, 'DEBUG', qr/^\[INFO\] Skipping nonexistent resource directory: /);
    downgrade($r, 'DEBUG', qr/^\[INFO\] No sources to compile\.\s*$/);

    # fmt-maven-plugin and license plugin report processed file counts. Zero
    # non-complying or zero reformatted means the check passed; the count
    # carries no signal.
    downgrade($r, 'TRACE', qr/^\[INFO\] (?:info )?Processed \d+ files? \(0 (?:non-complying|reformatted)\)/);

    # frontend-maven-plugin downloads and installs a local Node binary when
    # the required version is not already cached in the M2 repository. These
    # lines confirm the installation steps completed. They are only useful
    # when the node installation itself fails, not during every passing build.
    downgrade($r, 'TRACE', qr/^\[INFO\] (?:Installing node version |Unpacking .+\/node-[\d.]+-|Copying node binary |Installed node locally\.)/);

    # The frontend plugin logs the yarn install invocation it is about to run.
    # The line confirms yarn started but adds nothing beyond what a yarn failure
    # would reveal. Only needed when diagnosing why yarn never ran at all.
    downgrade($r, 'TRACE', qr/^\[INFO\] Running 'yarn install' in /);

    # yarn install output that is structural noise on every docs build. The
    # package-lock conflict fires because docs tracks both yarn.lock and
    # package-lock.json. The Node punycode deprecation and unmet peer
    # dependency warnings come from known stale packages in the Antora toolchain
    # and require no action. The lockfile save confirmation is a success echo.
    downgrade($r, 'TRACE', qr/^\[INFO\] warning package-lock\.json found/);
    downgrade($r, 'TRACE', qr/^\[INFO\] \(node:\d+\)/);
    downgrade($r, 'TRACE', qr/^\[INFO\] \(Use .+--trace-deprecation/);
    downgrade($r, 'TRACE', qr/^\[INFO\] warning ".*" has unmet peer dependency /);
    downgrade($r, 'TRACE', qr/^\[INFO\] success Saved lockfile\b/);

    # Maven prints mojo start and end markers around each goal execution.
    # At INFO they flood multi-module builds with dozens of lines, but at TRACE
    # they pinpoint which goal was running at the moment a failure occurred,
    # which is otherwise hard to determine from the error message alone.
    downgrade($r, 'TRACE', qr/^\[INFO\] >>> /);
    downgrade($r, 'TRACE', qr/^\[INFO\] <<< /);

    # Scanning for projects marks the point where Maven takes control from
    # pre-build steps like yarn formatting. Its timestamp establishes a baseline
    # for measuring Maven wall-clock time separately from qb wrapper overhead.
    downgrade($r, 'TRACE', qr/^\[INFO\] Scanning for projects/);

    # Maven logs one line per artifact download. Large builds produce hundreds
    # of these. At TRACE they confirm whether a missing dependency was never
    # fetched, which distinguishes a network failure from a source error.
    downgrade($r, 'TRACE', qr/^\[INFO\] Downloading from /);
    downgrade($r, 'TRACE', qr/^\[INFO\] Downloaded from /);

    # Maven suppresses retry attempts for artifacts that already failed in the
    # session. This WARNING was previously dropped entirely, leaving a silent
    # gap: Maven gave up without retrying and the build later fails with a
    # compile error that looks unrelated. At TRACE it is available when
    # diagnosing why a dependency is missing. Pattern covers both the
    # "previous attempt" phrasing in older Maven versions and the "this session"
    # phrasing in newer ones.
    downgrade($r, 'TRACE', qr/^\[WARNING\] .+failed to transfer from .+ during (?:a previous attempt|this session)/);

    # buildnumber-maven-plugin stores the resolved branch name and commit hash
    # in the project properties at build time. These lines confirm which values
    # were embedded in the artifact, which is needed when tracing a release
    # back to a specific commit or verifying a CI build used the right branch.
    downgrade($r, 'TRACE', qr/^\[INFO\] Storing (?:buildNumber|scmBranch|buildScmBranch): /);

    # Shade plugin warns when a shaded bundle contains module-info.class. This
    # fires on every OSGi bundle shade and is expected; the shade plugin handles
    # it correctly despite the warning.
    downgrade($r, 'DEBUG', qr/^\[WARNING\] Discovered module-info\.class\./);

    # Shade artifact replacement confirms the uber-jar was assembled. The build
    # result communicates success or failure without this intermediate step.
    downgrade($r, 'TRACE', qr/^\[INFO\] Replacing original artifact with shaded artifact\./);

    # Spring Boot repackager renames the original jar to .original after creating
    # the fat jar. The rename is structural; the "Replacing main artifact" line
    # above it already communicates what happened.
    downgrade($r, 'TRACE', qr/^\[INFO\] The original artifact has been renamed to /);

    # Shade inclusion lines enumerate every artifact bundled into the uber-jar.
    # Useful when debugging missing classes; irrelevant during passing builds.
    downgrade($r, 'TRACE', qr/^\[INFO\] Including .+ in the shaded jar\.$/);

    # Assembly plugin copies each transitive dependency jar into the distribution.
    # Hundreds of these fire per build; they add no signal beyond confirming the
    # assembly ran, which the zip/tar creation line already communicates.
    downgrade($r, 'TRACE', qr/^\[INFO\] Copying artifact: /);

    # Assembly plugin cannot include pom-type artifacts that have no associated file.
    # Fires for every pom module in the assembly descriptor and is structural.
    downgrade($r, 'TRACE', qr/^\[WARNING\] Cannot include project artifact: .+:pom:/);

    # Multi-release jar classes under META-INF/versions/ confuse the bundle plugin.
    # These are structural JVM artifacts from libraries like SQLite and Lucene.
    downgrade($r, 'TRACE', qr/^\[WARNING\] Bundle .+ : Classes found in the wrong directory:/);

    # OSGi bundle exports packages whose implementation uses non-exported packages.
    # Demote to DEBUG so the detail is visible when investigating deployment failures.
    downgrade($r, 'DEBUG', qr/^\[WARNING\] Bundle .+ : Export .+,\s+has \d+,\s+private references/);

    # Envfile property installs write build metadata to the local .m2 repository.
    # One fires per module; they are bookkeeping noise, not build milestones.
    downgrade($r, 'TRACE', qr/^\[INFO\] Installing .+ to .+-envfile\.properties$/);

    # Shade plugin writes a dependency-reduced POM alongside the shaded artifact.
    # Informational only; the artifact itself is the meaningful output.
    downgrade($r, 'TRACE', qr/^\[INFO\] Dependency-reduced POM written at: /);

    # Shade plugin replaces the original artifact with the shaded jar.
    # The path-form variant includes full file paths rather than the generic message.
    downgrade($r, 'TRACE', qr/^\[INFO\] Replacing .+\.jar with .+-shaded\.jar/);

    # maven-bundle-plugin writes the OSGi manifest and OBR index as intermediate
    # steps; the resulting bundle jar is the milestone, not these internal steps.
    downgrade($r, 'TRACE', qr/^\[INFO\] Writing manifest: /);
    downgrade($r, 'TRACE', qr/^\[INFO\] Writing OBR metadata\b/);

    # maven-bundle-plugin emits a second "Installing" line with a relative
    # bundle path but no source or destination details. Keep it available for
    # diagnosis without cluttering INFO where the full install context appears.
    downgrade($r, 'TRACE', qr/^\[INFO\] Installing [^\/\s].+\.jar\s*$/);

    # Incremental compiler recompiles the module when a dependency changes. This
    # fires for every module after fmt-maven-plugin touches source files during
    # formatting, making it structural noise on every incremental build.
    downgrade($r, 'TRACE', qr/^\[INFO\] Recompiling the module because of changed dependency\./);

    # Compiler confirms no sources changed since the last compile. Structural in
    # incremental builds; the build result communicates pass/fail without it.
    downgrade($r, 'DEBUG', qr/^\[INFO\] Nothing to compile - all classes are up to date\./);

    # Xlint advisory notes: the compiler emits a note for every file that uses
    # unchecked or deprecated APIs, then a follow-up prompting -Xlint. These
    # appear en masse for generated code and test utilities. Available at v4.
    downgrade($r, 'TRACE', qr/\buses (?:unchecked or unsafe operations|or overrides a deprecated API)\./);
    downgrade($r, 'TRACE', qr/\bRecompile with -Xlint:(?:unchecked|deprecation) for details\./);
    downgrade($r, 'TRACE', qr/\bSome input files use unchecked or unsafe operations\./);

    # CXF wsdl2java plugin logs each WSDL file it chooses not to process. These
    # fire for every WSDL resource in the source tree and carry no build signal.
    downgrade($r, 'TRACE', qr/^\[INFO\] Ignoring: file:/);

    # Assembly and codegen plugins log the artifact coordinates they are
    # processing as they configure the descriptor. One fires per dependency in
    # the assembly; they are bookkeeping noise, not build milestones.
    downgrade($r, 'TRACE', qr/^\[INFO\] Configured Artifact: /);

    # Helm chart plugin prints setup chatter on every build: repo-exists checks,
    # repo-update progress, and chart dependency downloads. Keep "Successfully
    # packaged" at INFO since it confirms the chart artifact was produced.
    downgrade($r, 'TRACE', qr/^\[INFO\] \[mvn-builder-cx-helm-chart\] (?!Successfully packaged)/);

    # "Some input files use or override a deprecated API" is the aggregate form
    # of the per-file Note: uses or overrides a deprecated API note. The per-file
    # form is already matched by the \buses pattern; this covers the plural form.
    downgrade($r, 'TRACE', qr/\bSome input files use or override a deprecated API\./);

    # ANTLR4 annotation processor declares source version RELEASE_6 and fires
    # this warning on every module compiled with --source 17. It is a stale
    # annotation in the upstream library and does not affect build output.
    downgrade($r, 'DEBUG', qr/^\[WARNING\] Supported source version 'RELEASE_\d+' from annotation processor .+ less than -source '\d+'/);

    # Docker builds run ffmpeg and gst-launch sanity checks during image layer
    # execution. The version banners carry no build signal.
    downgrade($r, 'TRACE', qr/^\[INFO\] DOCKER> ffmpeg version \d/);
    downgrade($r, 'TRACE', qr/^\[INFO\] DOCKER> gst-launch-1\.0 version /);

    # Karaf features plugin intermediate steps. The features-verified result
    # line is not matched here and stays at INFO.
    downgrade($r, 'TRACE', qr/^\[INFO\] Generation not enabled\s*$/);
    downgrade($r, 'TRACE', qr/^\[INFO\] Attaching artifact\s*$/);
    downgrade($r, 'TRACE', qr/^\[INFO\] Using (?:repositories|local repository at): /);
    downgrade($r, 'TRACE', qr/^\[INFO\] Installing .+features\.xml\b/);

    # Cache-hit confirmation from the DDF dependency unpack step. Repeats on
    # every build where the zip is already present.
    downgrade($r, 'TRACE', qr/^\[INFO\] .+\.zip already unpacked\b/);

    # Generic task start and end markers emitted with no goal or module context.
    downgrade($r, 'TRACE', qr/^\[INFO\] Execut(?:ing|ed) tasks\s*$/);

    # Next.js prints a static/dynamic legend after the route table. The table
    # itself is at DEBUG so the legend follows at the same level for context.
    downgrade($r, 'DEBUG', qr/^\[INFO\] [\x80-\xFF]+\s+\((?:Static|Dynamic)\)\s+/);

    # json tool confirmation that it updated a JSON file in-place. Fires for
    # package.json updates in the frontend build and carries no build signal.
    downgrade($r, 'TRACE', qr/^\[INFO\] json: updated ".+" in-place\s*$/);

    # Apollo GraphQL code generation progress lines. "Task started" and "Task
    # finished" stay at INFO as build milestones; intermediate steps do not.
    downgrade($r, 'TRACE', qr/^\[INFO\] Generating service: /);
    downgrade($r, 'TRACE', qr/^\[INFO\] Read schema file\b/);
    downgrade($r, 'TRACE', qr/^\[INFO\] Read (?:querie|fragment)\S* files\b/);
    downgrade($r, 'TRACE', qr/^\[INFO\] Add the compiled sources from .+ to project root\b/);
    downgrade($r, 'TRACE', qr/^\[INFO\] Total time:\s+\d+(?:\.\d+)?\s+s(?: \(Wall Clock\))?\s*$/);
}

# Emit a synthetic FAILED line immediately before a goal-execution error only
# when module ordering is deterministic. In threaded builds, the raw Maven
# error line is more trustworthy than a guessed module label.
sub emit_failed_marker {
    my $line = shift;
    return unless $allow_synthetic;
    return unless $line =~ /^\[ERROR\] Failed to execute goal\b.*\bon project /;
    print "[ERROR] FAILED $last_module_name\n" if defined $last_module_name;
}
