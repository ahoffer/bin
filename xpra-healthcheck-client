#!/usr/bin/env bash
set -euo pipefail

HOST="${XPRA_HEALTHCHECK_HOST:-bigfish}"
LOG="${XPRA_HEALTHCHECK_CLIENT_LOG:-${XPRA_HEALTHCHECK_LOG:-$HOME/Library/Logs/xpra-healthcheck-client.log}}"
LOCKDIR="${XPRA_HEALTHCHECK_CLIENT_LOCKDIR:-${XPRA_HEALTHCHECK_LOCKDIR:-${TMPDIR:-/tmp}/xpra-healthcheck-client.lock}}"
XPRA_BIN="${XPRA_HEALTHCHECK_XPRA_BIN:-/Applications/Xpra.app/Contents/MacOS/Xpra}"
STATE_DIR="${XPRA_HEALTHCHECK_CLIENT_STATE_DIR:-$HOME/Library/Caches/xpra-healthcheck-client}"
GRACE_SECONDS="${XPRA_HEALTHCHECK_GRACE_SECONDS:-120}"
RELAUNCH_COOLDOWN_SECONDS="${XPRA_HEALTHCHECK_RELAUNCH_COOLDOWN_SECONDS:-120}"

log() { echo "$(date -u +%FT%TZ) $*" >> "$LOG"; }

# macOS lacks GNU timeout, use perl alarm as portable alternative.
_timeout() { perl -e 'alarm shift; exec @ARGV or die $!' -- "$@"; }

# The previous watchdog used a global rule: if an Xpra PID did not currently
# own an ESTABLISHED socket on 14501/14502, it was killed as stale. That is too
# aggressive on macOS because freshly launched clients, idle clients, and
# clients between SSH tunnel states can temporarily lack that socket even though
# they are healthy. Those false positives caused needless client restarts and
# helped re-surface the Dock's bogus "bin" recent item. The revised logic keeps
# per-session launch state, treats recent launches and Xpra client sockets as
# signs of life, and waits through a grace window before recycling a session.

kill_pid_gracefully() {
    local pid="$1"
    if [ -z "$pid" ]; then
        return 0
    fi
    kill "$pid" 2>/dev/null || true
    for _ in 1 2 3; do
        if ! kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
        sleep 1
    done
    kill -9 "$pid" 2>/dev/null || true
}

kill_pattern_gracefully() {
    local pattern="$1"
    while IFS= read -r pid; do
        kill_pid_gracefully "$pid"
    done < <(pgrep -f "$pattern" 2>/dev/null || true)
}

# Format is session-name/port. Add a line here to introduce a new session.
sessions=("chrome/14501" "signal/14502")

state_file() { echo "${STATE_DIR}/$1.state"; }

load_session_state() {
    local session_name="$1"
    local file
    file="$(state_file "$session_name")"

    last_launch_epoch=0
    first_unhealthy_epoch=0
    last_healthy_epoch=0
    last_seen_client_pid=0

    if [ -f "$file" ]; then
        # State files are script-owned shell assignments, so sourcing them keeps
        # the persistence format small and readable.
        . "$file"
    fi
}

save_session_state() {
    local session_name="$1"
    local file
    file="$(state_file "$session_name")"
    mkdir -p "$STATE_DIR"
    cat >"$file" <<EOF
last_launch_epoch=${last_launch_epoch:-0}
first_unhealthy_epoch=${first_unhealthy_epoch:-0}
last_healthy_epoch=${last_healthy_epoch:-0}
last_seen_client_pid=${last_seen_client_pid:-0}
EOF
}

pid_is_running() {
    local pid="$1"
    [ -n "$pid" ] && [ "$pid" -gt 0 ] 2>/dev/null && kill -0 "$pid" 2>/dev/null
}

pid_age_seconds() {
    local pid="$1"
    local etime days time_part hours mins secs

    etime=$(ps -o etime= -p "$pid" 2>/dev/null | tr -d ' ' || true)
    [ -n "$etime" ] || return 1

    days=0
    if [[ "$etime" == *-* ]]; then
        days="${etime%%-*}"
        time_part="${etime#*-}"
    else
        time_part="$etime"
    fi

    hours=0
    mins=0
    secs=0
    IFS=: read -r a b c <<EOF
$time_part
EOF
    if [ -n "${c:-}" ]; then
        hours="$a"
        mins="$b"
        secs="$c"
    elif [ -n "${b:-}" ]; then
        mins="$a"
        secs="$b"
    else
        secs="$a"
    fi

    echo $((10#$secs + 60 * (10#$mins + 60 * (10#$hours + 24 * 10#$days))))
}

pid_has_established_session() {
    local pid="$1"
    lsof -nP -a -p "$pid" "${lsof_port_args[@]}" -sTCP:ESTABLISHED 2>/dev/null \
        | awk 'NR>1 {found=1} END {exit !found}'
}

pid_has_client_socket() {
    local pid="$1"
    find "$HOME/.xpra/clients" -maxdepth 1 -type s -name "*-$pid" 2>/dev/null \
        | awk 'NR==1 {found=1} END {exit !found}'
}

pid_is_live() {
    local pid="$1"
    local age

    pid_is_running "$pid" || return 1
    if pid_has_established_session "$pid"; then
        return 0
    fi
    if pid_has_client_socket "$pid"; then
        return 0
    fi
    age=$(pid_age_seconds "$pid" 2>/dev/null || echo 999999)
    [ "$age" -le "$GRACE_SECONDS" ]
}

session_pid_for_port() {
    local port="$1"
    lsof -nP -iTCP:"${port}" -sTCP:ESTABLISHED 2>/dev/null \
        | awk '$1=="Xpra" {print $2; exit}'
}

# Avoid overlapping launchd runs if a probe hangs.
# Use pid file inside lockdir to detect stale locks left by dead processes.
# Second mkdir after rm -rf guards the TOCTOU window between two racing cleaners.
if ! mkdir "$LOCKDIR" 2>/dev/null; then
    lock_pid=$(cat "$LOCKDIR/pid" 2>/dev/null || true)
    if [ -n "$lock_pid" ] && ! kill -0 "$lock_pid" 2>/dev/null; then
        log "removing stale lock held by dead pid $lock_pid"
        rm -rf "$LOCKDIR"
        if ! mkdir "$LOCKDIR" 2>/dev/null; then
            log "another run is active, skipping"
            exit 0
        fi
    else
        log "another run is active (pid ${lock_pid:-unknown}), skipping"
        exit 0
    fi
fi
echo $$ > "$LOCKDIR/pid"
trap 'rm -rf "$LOCKDIR"' EXIT

# Exit quietly if bigfish is unreachable, prevents launchd restart loops.
if ! ssh -o ConnectTimeout=3 -o BatchMode=yes -o ControlMaster=no "$HOST" true 2>/dev/null; then
    exit 0
fi

# Build a single lsof query from the configured sessions so ports are not duplicated.
lsof_port_args=()
for entry in "${sessions[@]}"; do
    lsof_port_args+=("-iTCP:${entry##*/}")
done

# Kill only truly orphaned Xpra processes. "No established connection right now"
# is not enough on its own because launch, idle, and reconnect windows can all
# look disconnected for a short time.
while IFS= read -r stale_pid; do
    if ! pid_is_live "$stale_pid"; then
        log "killing stale Xpra pid $stale_pid (no client socket, no session, age past grace)"
        kill_pid_gracefully "$stale_pid"
    fi
done < <(pgrep -x Xpra 2>/dev/null || true)

# Check each session and reconnect only the ones that are unhealthy.
for entry in "${sessions[@]}"; do
    session_name="${entry%%/*}"
    port="${entry##*/}"
    # Must match the control socket path used by xpra-start-client.
    control_path="${HOME}/.ssh/cm-xpra-${HOST}-${port}"
    now=$(date +%s)
    session_pid=0
    session_live=false

    tunnel_up=false
    probe_ok=false
    lsof -nP -iTCP:"${port}" -sTCP:LISTEN >/dev/null 2>&1 && tunnel_up=true

    if $tunnel_up && _timeout 10 "$XPRA_BIN" info "tcp://127.0.0.1:${port}" >/dev/null 2>&1; then
        probe_ok=true
    fi

    load_session_state "$session_name"
    session_pid=$(session_pid_for_port "$port" || true)
    if [ -n "$session_pid" ] && pid_is_live "$session_pid"; then
        session_live=true
        last_seen_client_pid="$session_pid"
    elif pid_is_live "$last_seen_client_pid"; then
        # A remembered pid with an Xpra client socket is still a live session
        # even if the TCP attach has not come back yet.
        session_live=true
    else
        last_seen_client_pid=0
    fi

    if $tunnel_up && $probe_ok; then
        first_unhealthy_epoch=0
        last_healthy_epoch="$now"
        save_session_state "$session_name"
        continue
    fi

    if [ "$first_unhealthy_epoch" -eq 0 ]; then
        first_unhealthy_epoch="$now"
    fi

    unhealthy_for=$((now - first_unhealthy_epoch))
    since_launch=$((now - last_launch_epoch))

    if $session_live || [ "$since_launch" -lt "$GRACE_SECONDS" ]; then
        log "port $port transient (tunnel=$tunnel_up probe=$probe_ok live_client=$session_live unhealthy_for=${unhealthy_for}s since_launch=${since_launch}s), skipping reconnect"
        save_session_state "$session_name"
        continue
    fi

    if [ "$last_launch_epoch" -gt 0 ] && [ "$since_launch" -lt "$RELAUNCH_COOLDOWN_SECONDS" ]; then
        log "port $port unhealthy but in relaunch cooldown (${since_launch}s < ${RELAUNCH_COOLDOWN_SECONDS}s), skipping reconnect"
        save_session_state "$session_name"
        continue
    fi

    if [ "$last_launch_epoch" -gt 0 ] && [ "$unhealthy_for" -lt "$GRACE_SECONDS" ]; then
        log "port $port unhealthy for ${unhealthy_for}s (< ${GRACE_SECONDS}s grace), skipping reconnect"
        save_session_state "$session_name"
        continue
    fi

    if [ "$last_launch_epoch" -eq 0 ] && [ "$last_healthy_epoch" -eq 0 ]; then
        log "port $port has no prior launch state, starting $session_name immediately"
    else
        log "port $port unhealthy (tunnel=$tunnel_up probe=$probe_ok live_client=$session_live), reconnecting $session_name"
    fi

    # Kill only the Xpra client bound to this port and its dedicated tunnel.
    # Avoid killing unrelated SSH sessions that may share the same destination host.
    while IFS= read -r xpra_pid; do
        kill_pid_gracefully "$xpra_pid"
    done < <(lsof -nP -iTCP:"${port}" -sTCP:ESTABLISHED 2>/dev/null | awk '$1=="Xpra" {print $2}' | sort -u)
    ssh -S "${control_path}" -O exit "${HOST}" >/dev/null 2>&1 || true
    kill_pattern_gracefully "ssh.*-o ControlPath=${control_path}.*${port}:127.0.0.1:${port}"
    sleep 2

    "$(dirname "$0")/xpra-start-client" "$session_name"
    load_session_state "$session_name"
    last_seen_client_pid=0
    save_session_state "$session_name"
done
