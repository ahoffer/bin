#!/usr/bin/env bash
#
# Quick build for local development. Runs the formatter and license header
# fixer before compiling so the build never fails over formatting drift,
# and skips tests by default to keep iteration fast.
#
# Designed to run on both macOS and Linux in regular git checkouts as well
# as linked worktrees across the marrs and cx-search repos, so the control
# flow needs to handle each layout explicitly instead of assuming a single
# repository shape.
#
# In docs modules, delegates to builddocs so the docs-specific worktree,
# bare-parent, and regular-repo handling lives in one script. In frontend
# modules, runs yarn prettier first because the TypeScript compiler rejects
# unformatted code.
#
# In a git worktree, skips the license plugin because jgit does not support
# linked worktrees. At the project root, docs preparation is delegated to
# builddocs, and docs are excluded from the main reactor only when qb itself
# is selecting the full reactor rather than honoring an explicit -pl.
#
# For Docker build contexts, qb can also infer a single deploy target
# architecture from the active kubectl cluster. This keeps routine local
# builds aligned with the current deployment target without forcing a
# second architecture by default. Explicit overrides via -a/--arch or
# QB_ARCH still win.

skip_tests=true
threads="-T6"
filter_level="${MVNFILTER_LEVEL:-4}"
filter_threaded=1
mvn_args=()
goals=()

# Target architecture for docker image builds. Empty means native,
# no cross-compilation. Set via -a flag or QB_ARCH env var
# to cross-compile via buildx after the Maven build. When unset in a
# Docker build context, qb will infer the target from the active kubectl
# cluster. This keeps one-arch builds pointed at the current deploy target
# while preserving explicit operator control.
arch="${QB_ARCH:-}"

original_args=("$@")
has_project_list=false

# On macOS, SSH sessions omit /opt/homebrew/bin from PATH, so mvn, docker,
# colima, and other Homebrew tools are unreachable. Prepend it unconditionally.
[[ "$(uname -s)" == Darwin && -d /opt/homebrew/bin ]] && export PATH="/opt/homebrew/bin:$PATH"

now_iso_utc() {
    date -u '+%Y-%m-%dT%H:%M:%SZ'
}

emit_qb_colored_stdout() {
    local line="$1"
    if command -v mvncolor >/dev/null 2>&1; then
        printf '%s\n' "$line" | mvncolor
    else
        printf '%s\n' "$line"
    fi
}

emit_qb_colored_stderr() {
    local line="$1"
    if command -v mvncolor >/dev/null 2>&1; then
        printf '%s\n' "$line" | mvncolor >&2
    else
        printf '%s\n' "$line" >&2
    fi
}

emit_qb_info() {
    emit_qb_colored_stdout "$(now_iso_utc) INFO $1"
}

emit_qb_info_at_level() {
    local min_level="$1"
    shift
    [[ "$filter_level" =~ ^[0-9]+$ ]] || return 0
    (( filter_level >= min_level )) || return 0
    emit_qb_info "$*"
}

emit_qb_warning() {
    [[ "$filter_level" =~ ^[0-9]+$ ]] || return 0
    (( filter_level >= 3 )) || return 0
    emit_qb_colored_stderr "$(now_iso_utc) WARNING $1"
}

qb_started_epoch=$(date +%s)

supplement_build_summary() {
    local status="$1"
    local qb_finished_epoch elapsed time_str
    qb_finished_epoch=$(date +%s)
    elapsed=$((qb_finished_epoch - qb_started_epoch))
    if [[ $status -eq 0 ]] && (( filter_level < 4 )); then
        emit_qb_info "BUILD SUCCESS"
    fi
    local show_time=0
    (( elapsed <  60 && filter_level < 6 )) && show_time=1
    (( elapsed >= 60 && filter_level < 4 )) && show_time=1
    if (( show_time )); then
        if (( elapsed >= 60 )); then
            time_str=$(printf '%d:%02d min' $((elapsed / 60)) $((elapsed % 60)))
        else
            time_str="${elapsed}s"
        fi
        emit_qb_info "Total time:  ${time_str} (Wall Clock)"
    fi
}


require_value() {
    local opt="$1"
    local val="${2:-}"
    if [[ -z "$val" || "$val" == -* ]]; then
        echo "Error: $opt requires a value." >&2
        echo "Usage: qb [OPTIONS] [MAVEN-GOALS]" >&2
        exit 2
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -t|--test) skip_tests=false ;;
        -1|--single-thread) threads="" ;;
        -v[0-9]) filter_level="${1#-v}" ;;
        -a|--arch) require_value "$1" "${2:-}"; arch="$2"; shift ;;
        -h|--help)
            cat <<'EOF'
Usage: qb [OPTIONS] [MAVEN-GOALS]

Wraps mvn for local development. Formats code and fixes license headers
before compiling so the build never fails over formatting drift.
Default goal is install with 6 threads. Tests are skipped unless -t is passed.

  -t              Run tests, skipped by default to keep iteration fast
  -1              Single-threaded build, useful for debugging output order
  -v0             Silent
  -v1             Maven stderr only, stdout suppressed
  -v2             v1 plus qb metadata and [ERROR] lines
  -v3             v2 plus [WARNING] lines
  -v4             Default, v3 plus [INFO] lines
  -v5             v4 plus demoted [DEBUG] lines
  -v6             v5 plus demoted [TRACE] lines
  -v7             Raw Maven output, no filtering
  -T <n>          Override thread count, default is 6
  -a <platform>   Cross-compile Docker images via buildx after Maven for a
                  different CPU, for example linux/amd64 or linux/arm64.
                  Set QB_ARCH in the environment to avoid repeating.
                  When omitted in a Docker build context, qb infers the
                  target from the active kubectl cluster.
  -h              Show this help

All other flags pass through to mvn, including -pl, -rf, -P, -am, and -f.
EOF
            exit 0
            ;;
        -T)
            require_value "$1" "${2:-}"
            if [[ ! "$2" =~ ^[0-9]+$ ]]; then
                echo "Error: -T requires a numeric thread count (e.g. 6 or 8)." >&2
                exit 2
            fi
            threads="-T$2"
            shift
            ;;
        -am) mvn_args+=("$1") ;;
        -pl|-rf|-P|-f|-s|-gs)
            require_value "$1" "${2:-}"
            [[ "$1" == "-pl" ]] && has_project_list=true
            mvn_args+=("$1" "$2")
            shift
            ;;
        -*) mvn_args+=("$1") ;;
        *) goals+=("$1") ;;
    esac
    shift
done

[[ ${#goals[@]} -eq 0 ]] && goals=(install)
[[ -z "$threads" ]] && filter_threaded=0
if $skip_tests; then
    mvn_args+=("-DskipTests" "-Djacoco.skip=true")
fi

emit_log_level_info() {
    local label
    case "$filter_level" in
        0) label="silent" ;;
        1) label="stderr" ;;
        2) label="errors" ;;
        3) label="warnings" ;;
        4) label="info" ;;
        5) label="debug" ;;
        6) label="trace" ;;
        *) label="raw" ;;
    esac
    emit_qb_info "qb log level: v${filter_level} (${label})"
}

collapse_known_error_blocks() {
    perl -0pe 's/\n?\s*Node Version Check:\n(?:.*\n)*?\s*Project requires Node ([^\n]+)\nYou are running Node ([^\n]+)\n(?:    at .*\n)*/\nERROR Node version mismatch: requires $1; current $2\n/s'
}

_qb_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
_qb_hash=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
if [[ $filter_level -ge 2 ]]; then
    emit_qb_info "Starting build..."
    emit_log_level_info
fi

git_root=$(git rev-parse --show-toplevel 2>/dev/null) || true

# When git resolves to a parent directory but the current directory looks like
# a standalone project root (has pom.xml and docs/content), Antora fails because
# it requires master/ itself to be a git repo. Create a minimal temporary repo
# scoped to PWD and register a trap to remove it on exit.
_qb_fake_git_dir=""
_qb_cleanup_fake_git() { [[ -n "$_qb_fake_git_dir" ]] && rm -rf "$_qb_fake_git_dir"; }
trap _qb_cleanup_fake_git EXIT
_qb_pwd_real=$(realpath "$PWD")
if [[ -f "pom.xml" && -d "docs/content" && ( -z "$git_root" || "$_qb_pwd_real" != "$(realpath "$git_root")" ) ]]; then
    _qb_fake_git_dir="${_qb_pwd_real}/.git"
    git -C "$PWD" init >/dev/null 2>&1
    git -C "$PWD" add docs/content/ >/dev/null 2>&1
    git -C "$PWD" -c user.name=tmp -c user.email=tmp@tmp commit -m tmp >/dev/null 2>&1
    git_root=$_qb_pwd_real
fi

# Returns the path of PWD relative to git_root, with no leading slash.
# Returns empty string when PWD is the git root itself.
git_rel() {
    [[ -n "$git_root" ]] || return 1
    local r
    r=$(realpath "$PWD")
    r="${r#"$git_root"}"
    echo "${r#/}"
}

# Returns true when PWD is inside the frontend module or at the project
# root that contains a frontend module.
is_frontend_context() {
    [[ -n "$git_root" ]] || return 1
    [[ -d "$git_root/frontend" ]] || return 1
    local rel
    rel=$(git_rel)
    [[ -z "$rel" || "$rel" == "frontend" || "$rel" == frontend/* ]]
}

ensure_yarn_available() {
    command -v yarn >/dev/null 2>&1 && return 0
    command -v corepack >/dev/null 2>&1 || {
        echo "Error: yarn is not on PATH and corepack is unavailable." >&2
        exit 1
    }
    emit_qb_info_at_level 4 "yarn not found on PATH; running corepack enable"
    corepack enable >/dev/null 2>&1 || {
        echo "Error: failed to enable yarn via corepack." >&2
        exit 1
    }
    hash -r
    command -v yarn >/dev/null 2>&1 || {
        echo "Error: yarn is still unavailable after corepack enable." >&2
        exit 1
    }
}

ensure_required_node_version() {
    local req cur
    req=$(sed -n 's:.*<node.version>\(.*\)</node.version>.*:\1:p' "$git_root/pom.xml" | head -n1)
    [[ -n "$req" ]] || return 0
    cur=$(node -v 2>/dev/null | sed 's/^v//')
    awk -v a="$cur" -v b="$req" 'BEGIN{split(a,A,".");split(b,B,".");for(i=1;i<=3;i++){if(A[i]+0>B[i]+0)exit 0;if(A[i]+0<B[i]+0)exit 1}exit 0}' && return 0
    export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
    . "$NVM_DIR/nvm.sh" && nvm use "$req" >/dev/null 2>&1 || { echo "Error: Node v$req required; run: nvm install $req" >&2; exit 1; }
    hash -r
    emit_qb_info_at_level 4 "qb node version: $(node -v)"
}

format_frontend() {
    is_frontend_context || return 0
    (
        cd "$git_root/frontend" || { echo "Error: frontend directory not found at $git_root/frontend." >&2; exit 1; }
        ensure_required_node_version
        ensure_yarn_available
        if [[ ! -d node_modules ]]; then
            MVNFILTER_LEVEL=$filter_level yarn install | collapse_known_error_blocks | yarnfilter | yarnwarn | mvncolor
            exit_code=${PIPESTATUS[0]}
            [[ $exit_code -eq 0 ]] || exit $exit_code
        fi
        MVNFILTER_LEVEL=$filter_level yarn fix | collapse_known_error_blocks | yarnfilter | yarnwarn | mvncolor
        exit ${PIPESTATUS[0]}
    )
}

is_docs_context() {
    [[ -n "$git_root" ]] || return 1
    local rel
    rel=$(git_rel)
    [[ "$rel" == "docs" || "$rel" == docs/* ]]
}

# A worktree has a .git file instead of a .git directory.
is_worktree() {
    [[ -n "$git_root" ]] && [[ -f "$git_root/.git" ]]
}

# Returns true when the root pom.xml declares an artifact with the given ID.
# Used to skip formatter goals in projects that do not define the plugin.
pom_declares_plugin() {
    local artifact_id="$1"
    local root_pom="${git_root:-.}/pom.xml"
    [[ -f "$root_pom" ]] && grep -q "<artifactId>${artifact_id}</artifactId>" "$root_pom"
}

# Prints the groupId declared alongside fmt-maven-plugin in the root pom.xml.
# The groupId line appears just before the artifactId line in a standard plugin stanza.
# Prints nothing and returns 1 when the plugin is absent or groupId cannot be found.
fmt_plugin_groupid() {
    local root_pom="${git_root:-.}/pom.xml"
    [[ -f "$root_pom" ]] || return 1
    local groupid
    groupid=$(grep -B5 "<artifactId>fmt-maven-plugin</artifactId>" "$root_pom" \
        | grep "<groupId>" | tail -1 \
        | sed 's/[[:space:]]*<groupId>\([^<]*\)<\/groupId>.*/\1/')
    [[ -n "$groupid" ]] && echo "$groupid"
}

is_project_root() {
    [[ -n "$git_root" ]] && [[ "$(realpath "$PWD")" == "$(realpath "$git_root")" ]]
}

is_projects_docker_context() {
    local resolved_pwd rel
    resolved_pwd=$(realpath "$PWD")
    [[ "$resolved_pwd" == "$HOME/projects/"* ]] || return 1
    rel="${resolved_pwd#"$HOME/projects/"}"
    [[ "/$rel/" == *"/docker/"* ]]
}

is_docker_build_context() {
    is_projects_docker_context && return 0
    is_project_root && [[ -d "$git_root/docker" ]]
}

map_arch_to_platform() {
    case "$1" in
        amd64|x86_64) echo "linux/amd64" ;;
        arm64|aarch64) echo "linux/arm64" ;;
        *) return 1 ;;
    esac
}

# Best-effort arch detection from the current kubectl target. This is only
# used to choose a single deploy architecture when the operator did not
# explicitly request one with -a/--arch or QB_ARCH.
infer_arch_from_cluster() {
    command -v kubectl >/dev/null 2>&1 || return 1
    local raw
    raw=$(kubectl get nodes -o jsonpath='{.items[0].status.nodeInfo.architecture}' 2>/dev/null) || return 1
    [[ -n "$raw" ]] || return 1
    map_arch_to_platform "$raw"
}

# Resolve the effective target architecture for Docker-oriented builds.
# Precedence is:
# 1. explicit -a/--arch
# 2. QB_ARCH from the environment
# 3. active kubectl cluster architecture
# 4. native Docker build (empty arch)
resolve_qb_target_arch() {
    [[ -n "$arch" ]] && return 0
    is_docker_build_context || return 0

    local inferred_arch
    inferred_arch=$(infer_arch_from_cluster) || return 0
    arch="$inferred_arch"
    emit_qb_info_at_level 4 "qb inferred deploy architecture from cluster: ${arch}"
}

# On macOS, SSH sessions do not include /opt/homebrew/bin in PATH, so colima
# and docker are unreachable even when installed. This function starts Colima
# if it is installed but not yet running, then returns. On Linux it is a no-op.
ensure_colima_started_if_needed() {
    [[ "$(uname -s)" == Darwin ]] || return 0
    local colima=/opt/homebrew/bin/colima
    [[ -x "$colima" ]] || return 0
    local sock="$HOME/.colima/default/docker.sock"
    [[ -S "$sock" ]] && return 0
    emit_qb_info "Starting Colima..."
    "$colima" start >/dev/null 2>&1 || { echo "Error: colima start failed." >&2; exit 1; }
    local i
    for i in $(seq 1 30); do
        [[ -S "$sock" ]] && return 0
        sleep 2
    done
    echo "Error: Colima started but docker socket not ready after 60s." >&2
    exit 1
}

ensure_docker_daemon_if_needed() {
    is_docker_build_context || return 0

    if ! command -v docker >/dev/null 2>&1; then
        echo "Error: docker is required for builds under ~/projects/**/docker, but the docker CLI is not installed." >&2
        exit 1
    fi

    ensure_colima_started_if_needed

    # Colima may be running but DOCKER_HOST not set in this session.
    if ! docker info >/dev/null 2>&1; then
        local sock="$HOME/.colima/default/docker.sock"
        [[ -S "$sock" ]] && export DOCKER_HOST="unix://$sock"
    fi

    if ! docker info >/dev/null 2>&1; then
        echo "Error: docker daemon is unavailable for builds under ~/projects/**/docker." >&2
        if [[ -n "${DOCKER_HOST:-}" ]]; then
            echo "Current DOCKER_HOST: ${DOCKER_HOST}" >&2
        fi
        echo "Start Colima/Docker first, then rerun qb." >&2
        exit 1
    fi
}

ensure_colima_shape_if_needed(){ is_docker_build_context||return 0; local c=/opt/homebrew/bin/colima j; [[ -x $c ]]||return 0; j=$($c status --json 2>/dev/null)||return 0; printf %s "$j"|grep -q '"cpu":4'&&printf %s "$j"|grep -q '"memory":25769803776'&&printf %s "$j"|grep -q '"disk":274877906944'&&return 0; echo "ERROR Colima config mismatch: expected cpu=4 memory=24GiB disk=256GiB. Fix with: colima stop && colima delete && colima start --cpu 4 --memory 24 --disk 256" >&2; exit 1; }

ensure_colima_space_if_needed() {
    is_docker_build_context || return 0
    local c=/opt/homebrew/bin/colima
    local df_line conf_json
    local size_k used_k avail_k conf_k
    local size_g used_g avail_g conf_g

    [[ -x $c ]] || return 0

    df_line=$($c ssh -- df -Pk / 2>/dev/null | awk 'NR==2 { print $2, $3, $4 }')
    conf_json=$($c status --json 2>/dev/null) || conf_json=''

    read -r size_k used_k avail_k <<< "$df_line"
    [[ $size_k =~ ^[0-9]+$ && $used_k =~ ^[0-9]+$ && $avail_k =~ ^[0-9]+$ ]] || return 0

    size_g=$(awk -v k="$size_k" 'BEGIN { printf "%.1f", k / 1048576 }')
    used_g=$(awk -v k="$used_k" 'BEGIN { printf "%.1f", k / 1048576 }')
    avail_g=$(awk -v k="$avail_k" 'BEGIN { printf "%.1f", k / 1048576 }')

    conf_k=$(printf %s "$conf_json" | sed -n 's/.*"disk":\([0-9][0-9]*\).*/\1/p')
    if [[ $conf_k =~ ^[0-9]+$ ]]; then
        conf_g=$(awk -v b="$conf_k" 'BEGIN { printf "%.1f", b / 1073741824 }')
    fi

    if [[ -n ${conf_g:-} ]]; then
        emit_qb_info_at_level 4 "qb colima disk usage: ${used_g} GiB used; configured capacity ${conf_g} GiB"
    else
        emit_qb_info_at_level 4 "qb colima disk usage: ${used_g} GiB used"
    fi

    (( avail_k < 2097152 )) && {
        echo "ERROR Colima free space too low for Docker build: $avail_g GiB available, need at least 2.0 GiB" >&2
        exit 1
    }
    (( avail_k < 5242880 )) && emit_qb_warning "Colima free space is low for Docker build: $avail_g GiB available"
}

if is_docs_context; then
    exec "$HOME/bin/builddocs" "${original_args[@]}"
fi

ensure_docker_daemon_if_needed
ensure_colima_shape_if_needed
ensure_colima_space_if_needed
resolve_qb_target_arch

"$HOME/bin/builddocs"

format_frontend || exit $?

# The license plugin uses jgit, which does not support linked worktrees.
# Skip license formatting in worktrees to avoid a bare-repository error.
# When qb is driving the whole reactor from a worktree root, exclude docs
# because builddocs already prepared them separately.
if is_worktree; then
    mvn_args+=("-Dlicense.skip=true")
    if ! $has_project_list && is_project_root && [[ -d "$git_root/docs" ]]; then
        mvn_args+=("-pl" "!docs")
    fi
fi

# Always format and fix license headers before compiling.
format_goals=()
fmt_groupid=$(fmt_plugin_groupid) && format_goals+=("${fmt_groupid}:fmt-maven-plugin:format")
pom_declares_plugin "license-maven-plugin" && format_goals+=("license:format")
goals=("${format_goals[@]}" "${goals[@]}")

if [[ $filter_level -eq 0 ]]; then
    MVNFILTER_LEVEL=$filter_level mvn $threads --no-transfer-progress "${mvn_args[@]}" "${goals[@]}" >/dev/null 2>&1
    build_status=$?
elif [[ $filter_level -eq 1 ]]; then
    MVNFILTER_LEVEL=$filter_level mvn $threads --no-transfer-progress "${mvn_args[@]}" "${goals[@]}" >/dev/null
    build_status=$?
elif [[ $filter_level -ge 7 ]]; then
    emit_qb_info "Starting build \"${_qb_branch} ${_qb_hash}\""
    MVNFILTER_LEVEL=$filter_level mvn $threads --no-transfer-progress "${mvn_args[@]}" "${goals[@]}"
    build_status=$?
else
    { printf '[INFO] Starting build "%s %s"\n' "$_qb_branch" "$_qb_hash"
      MVNFILTER_LEVEL=$filter_level mvn $threads --no-transfer-progress "${mvn_args[@]}" "${goals[@]}"
    } \
        | MVNFILTER_THREADED=$filter_threaded mvnfilter \
        | mvnformat \
        | mvnts \
        | mvntrim \
        | mvnyarnclean \
        | mvnreactordebug \
        | mvndockerdebug \
        | mvnbranchdebug \
        | mvnparallelcondense \
        | mvnshadenoise \
        | mvnlevelcaps \
        | mvnzerofilesnoise \
        | MVNFILTER_THREADED=$filter_threaded mvnthreadednoise \
        | MVNFILTER_LEVEL=$filter_level mvnlevel \
        | mvncolor
    build_status=${PIPESTATUS[0]}
    supplement_build_summary "$build_status"
fi

# Deferred work only makes sense after a successful Maven phase. This keeps
# the primary failure intact while still allowing worktree-root docs builds
# and optional cross-builds to run when the main build succeeds.
[[ $build_status -eq 0 ]] || exit $build_status

# When the target architecture differs from the host, rebuild Docker
# images using buildx. In a docker module directory, rebuilds just
# that component. At the project root, finds all docker modules that
# Maven built and rebuilds each.
if [[ -n "$arch" ]]; then
    emit_qb_info "qb post-build buildx target: ${arch}"
    [[ -f "$HOME/bin/cx.lib" ]] || { echo "Error: cx.lib not found at $HOME/bin/cx.lib." >&2; exit 1; }
    source "$HOME/bin/cx.lib"
    if needs_cross_build "$arch"; then
        require_project_root
        if is_projects_docker_context; then
            componentName=$(basename "$(realpath "$PWD")")
            buildx_rebuild "$PROJECT_ROOT" "$componentName" "$arch" || exit $?
        elif is_project_root; then
            for dockerTargetDir in "$PROJECT_ROOT"/docker/*/target/docker; do
                [[ -d "$dockerTargetDir" ]] || continue
                componentName=$(basename "$(dirname "$(dirname "$dockerTargetDir")")")
                buildx_rebuild "$PROJECT_ROOT" "$componentName" "$arch" || exit $?
            done
        fi
    fi
fi

exit 0
