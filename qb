#!/usr/bin/env bash
#
# Quick build for local development. Runs the formatter and license header
# fixer before compiling so the build never fails over formatting drift,
# and skips tests by default to keep iteration fast.
#
# In docs modules, delegates to docbuild because Antora cannot be driven
# through Maven. In frontend modules, runs yarn prettier first because
# the TypeScript compiler rejects unformatted code.
#
# In a git worktree, skips the license plugin because jgit does not support
# linked worktrees. Full builds at the project root also exclude docs from
# Maven and build them via docbuild afterward, because Antora cannot resolve
# content sources from a worktree.

skip_tests=true
threads="-T6"
filter_level="${MVNFILTER_LEVEL:-1}"
mvn_args=()
goals=()

# Target architecture for docker image builds. Empty means native,
# no cross-compilation. Set via -a flag or CONTAINER_ARCH env var
# to cross-compile via buildx after the Maven build.
arch="${CONTAINER_ARCH:-}"

original_args=("$@")
readonly docbuild="$HOME/bin/cxappdev/docbuild"

require_value() {
    local opt="$1"
    local val="${2:-}"
    if [[ -z "$val" || "$val" == -* ]]; then
        echo "Error: $opt requires a value." >&2
        echo "Usage: qb [OPTIONS] [MAVEN-GOALS]" >&2
        exit 2
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -t|--test) skip_tests=false ;;
        -1|--single-thread) threads="" ;;
        -v[0-9]) filter_level="${1#-v}" ;;
        -a|--arch) require_value "$1" "${2:-}"; arch="$2"; shift ;;
        -h|--help)
            cat <<'EOF'
Usage: qb [OPTIONS] [MAVEN-GOALS]

Wraps mvn for local development. Formats code and fixes license headers
before compiling so the build never fails over formatting drift.
Default goal is install with 6 threads. Tests are skipped unless -t is passed.

  -t              Run tests, skipped by default to keep iteration fast
  -1              Single-threaded build, useful for debugging output order
  -v0             Suppress informational output, show only errors and build outcome
  -v2             Show plugin goal lines, useful when debugging build configuration
  -T <n>          Override thread count, default is 6
  -a <platform>   Cross-compile Docker images via buildx after Maven for a
                  different CPU, for example linux/amd64 or linux/arm64.
                  Set CONTAINER_ARCH in the environment to avoid repeating.
  -h              Show this help

All other flags pass through to mvn, including -pl, -rf, -P, -am, and -f.
EOF
            exit 0
            ;;
        -T)
            require_value "$1" "${2:-}"
            if [[ ! "$2" =~ ^[0-9]+$ ]]; then
                echo "Error: -T requires a numeric thread count (e.g. 6 or 8)." >&2
                exit 2
            fi
            threads="-T$2"
            shift
            ;;
        -am) mvn_args+=("$1") ;;
        -pl|-rf|-P|-f|-s|-gs)
            require_value "$1" "${2:-}"
            mvn_args+=("$1" "$2")
            shift
            ;;
        -*) mvn_args+=("$1") ;;
        *) goals+=("$1") ;;
    esac
    shift
done

[[ ${#goals[@]} -eq 0 ]] && goals=(install)
if $skip_tests; then
    mvn_args+=("-DskipTests" "-Djacoco.skip=true")
fi

git_root=$(git rev-parse --show-toplevel 2>/dev/null) || true

# Returns the path of PWD relative to git_root, with no leading slash.
# Returns empty string when PWD is the git root itself.
git_rel() {
    [[ -n "$git_root" ]] || return 1
    local r
    r=$(realpath "$PWD")
    r="${r#"$git_root"}"
    echo "${r#/}"
}

# Returns true when PWD is inside the frontend module or at the project
# root that contains a frontend module.
is_frontend_context() {
    [[ -n "$git_root" ]] || return 1
    [[ -d "$git_root/frontend" ]] || return 1
    local rel
    rel=$(git_rel)
    [[ -z "$rel" || "$rel" == "frontend" || "$rel" == frontend/* ]]
}

format_frontend() {
    is_frontend_context || return 0
    (
        cd "$git_root/frontend" || { echo "Error: frontend directory not found at $git_root/frontend." >&2; exit 1; }
        if [[ ! -d node_modules ]]; then
            MVNFILTER_LEVEL=$filter_level yarn install | yarnfilter | yarnwarn | mvncolor
            exit_code=${PIPESTATUS[0]}
            [[ $exit_code -eq 0 ]] || exit $exit_code
        fi
        MVNFILTER_LEVEL=$filter_level yarn fix | yarnfilter | yarnwarn | mvncolor
        exit ${PIPESTATUS[0]}
    )
}

is_docs_context() {
    [[ -n "$git_root" ]] || return 1
    local rel
    rel=$(git_rel)
    [[ "$rel" == "docs" || "$rel" == docs/* ]]
}

# A worktree has a .git file instead of a .git directory.
is_worktree() {
    [[ -n "$git_root" ]] && [[ -f "$git_root/.git" ]]
}

is_project_root() {
    [[ -n "$git_root" ]] && [[ "$(realpath "$PWD")" == "$(realpath "$git_root")" ]]
}

is_projects_docker_context() {
    local resolved_pwd rel
    resolved_pwd=$(realpath "$PWD")
    [[ "$resolved_pwd" == "$HOME/projects/"* ]] || return 1
    rel="${resolved_pwd#"$HOME/projects/"}"
    [[ "/$rel/" == *"/docker/"* ]]
}

ensure_docker_daemon_if_needed() {
    is_projects_docker_context || return 0

    if ! command -v docker >/dev/null 2>&1; then
        echo "Error: docker is required for builds under ~/projects/**/docker, but the docker CLI is not installed." >&2
        exit 1
    fi

    if ! docker info >/dev/null 2>&1; then
        echo "Error: docker daemon is unavailable for builds under ~/projects/**/docker." >&2
        if [[ -n "${DOCKER_HOST:-}" ]]; then
            echo "Current DOCKER_HOST: ${DOCKER_HOST}" >&2
        fi
        echo "Start Colima/Docker first, then rerun qb." >&2
        exit 1
    fi
}

# The docs module uses Antora, not javac, so skip maven entirely.
if is_docs_context; then
    [[ -x "$docbuild" ]] || { echo "Error: docbuild not found at $docbuild." >&2; exit 1; }
    exec "$docbuild" "${original_args[@]}"
fi

ensure_docker_daemon_if_needed

format_frontend || exit $?

# The license plugin uses jgit, which does not support linked worktrees.
# Skip license formatting in worktrees to avoid a bare-repository error.
# At the project root, also exclude docs from Maven and build them via
# docbuild afterward, because Antora cannot resolve content sources from
# a worktree.
if is_worktree; then
    mvn_args+=("-Dlicense.skip=true")
    if is_project_root && [[ -d "$git_root/docs" ]]; then
        mvn_args+=("-pl" "!docs")
        build_docs_separately=true
    fi
fi

# Always format and fix license headers before compiling.
goals=(com.spotify.fmt:fmt-maven-plugin:format license:format "${goals[@]}")

MVNFILTER_LEVEL=$filter_level mvn $threads --no-transfer-progress "${mvn_args[@]}" "${goals[@]}" | mvnfilter | mvnformat | mvnts | mvntrim | mvncolor
exit ${PIPESTATUS[0]}

# When the target architecture differs from the host, rebuild Docker
# images using buildx. In a docker module directory, rebuilds just
# that component. At the project root, finds all docker modules that
# Maven built and rebuilds each.
if [[ -n "$arch" ]]; then
    [[ -f "$HOME/bin/cx.lib" ]] || { echo "Error: cx.lib not found at $HOME/bin/cx.lib." >&2; exit 1; }
    source "$HOME/bin/cx.lib"
    if needs_cross_build "$arch"; then
        require_project_root
        if is_projects_docker_context; then
            componentName=$(basename "$(realpath "$PWD")")
            buildx_rebuild "$PROJECT_ROOT" "$componentName" "$arch" || exit $?
        elif is_project_root; then
            for dockerTargetDir in "$PROJECT_ROOT"/docker/*/target/docker; do
                [[ -d "$dockerTargetDir" ]] || continue
                componentName=$(basename "$(dirname "$(dirname "$dockerTargetDir")")")
                buildx_rebuild "$PROJECT_ROOT" "$componentName" "$arch" || exit $?
            done
        fi
    fi
fi

if [[ "${build_docs_separately:-}" == true ]]; then
    ( cd "$git_root/docs" && "$docbuild" )
fi
