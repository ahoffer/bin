#!/usr/bin/env bash

skip_tests=true
threads="-T6"
mvn_args=()
goals=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -t|--test) skip_tests=false ;;
        -1|--single-thread) threads="" ;;
        -h|--help)
            echo "Usage: qb [OPTIONS] [MAVEN-GOALS]"
            echo "Options: -t (run tests), -1 (single-thread), -h (help)"
            exit 0
            ;;
        -*) mvn_args+=("$1") ;;
        *) goals+=("$1") ;;
    esac
    shift
done

[[ ${#goals[@]} -eq 0 ]] && goals=(install)
$skip_tests && mvn_args+=("-DskipTests")

git_root=$(git rev-parse --show-toplevel 2>/dev/null) || true

is_frontend_context() {
    [[ -d "$git_root/frontend" ]] || return 1
    local rel
    rel=$(realpath --relative-to="$git_root" "$PWD")
    [[ "$rel" == "." || "$rel" == "frontend" || "$rel" == frontend/* ]]
}

if is_frontend_context; then
    # Run prettier before Maven to avoid build failures. Install deps first if missing.
    (cd "$git_root/frontend" && [[ -d node_modules ]] || yarn install && yarn fix) || exit 1
fi

goals=(com.spotify.fmt:fmt-maven-plugin:format license:format "${goals[@]}")

exec mvn $threads "${mvn_args[@]}" "${goals[@]}"
