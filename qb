#!/usr/bin/env bash

skip_tests=true
threads="-T6"
mvn_args=()
goals=()

require_value() {
    local opt="$1"
    local val="${2:-}"
    if [[ -z "$val" || "$val" == -* ]]; then
        echo "Error: $opt requires a value." >&2
        echo "Usage: qb [OPTIONS] [MAVEN-GOALS]" >&2
        exit 2
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -t|--test) skip_tests=false ;;
        -1|--single-thread) threads="" ;;
        -h|--help)
            echo "Usage: qb [OPTIONS] [MAVEN-GOALS]"
            echo "Options: -t (run tests), -1 (single-thread), -h (help)"
            exit 0
            ;;
        -T)
            require_value "$1" "${2:-}"
            if [[ ! "$2" =~ ^[0-9]+$ ]]; then
                echo "Error: -T requires a numeric thread count (e.g. 6 or 8)." >&2
                exit 2
            fi
            threads="-T$2"
            shift
            ;;
        -pl|-am|-amd|-rf|-P|-f|-s|-gs)
            require_value "$1" "${2:-}"
            mvn_args+=("$1" "$2")
            shift
            ;;
        -*) mvn_args+=("$1") ;;
        *) goals+=("$1") ;;
    esac
    shift
done

[[ ${#goals[@]} -eq 0 ]] && goals=(install)
$skip_tests && mvn_args+=("-DskipTests")

git_root=$(git rev-parse --show-toplevel 2>/dev/null) || true

is_frontend_context() {
    [[ -n "$git_root" ]] || return 1
    [[ -d "$git_root/frontend" ]] || return 1
    local rel
    rel=$(realpath --relative-to="$git_root" "$PWD")
    [[ "$rel" == "." || "$rel" == "frontend" || "$rel" == frontend/* ]]
}

prepare_frontend_if_needed() {
    is_frontend_context || return 0

    # Run prettier before Maven to avoid build failures. Install deps first if missing.
    (
        cd "$git_root/frontend" || exit 1
        [[ -d node_modules ]] || yarn install
        yarn fix
    )
}

prepare_frontend_if_needed || exit 1

goals=(com.spotify.fmt:fmt-maven-plugin:format license:format "${goals[@]}")

exec mvn $threads "${mvn_args[@]}" "${goals[@]}"
