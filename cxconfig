#!/usr/bin/env bash
set -euo pipefail

# Query component configuration for cx or marrs projects
#
# Derives everything from project structure, pom files, and conventions.
# No config files needed. Must be run from within a project directory.
#
# Usage: cxconfig <command> [args]
#
# Commands:
#   components          List all component names
#   dir <component>     Get docker directory name for component (same as name)
#   deploy <component>  Get k8s deployment name for component
#   image <component>   Get full image:tag (registry/project/dir:version)
#   timeout             Get rollout timeout in seconds (default 300)
#   registry            Get the container registry URL
#   version             Get the current build version
#   namespace           Get the k8s namespace for this app
#   prefix              Get the deploy prefix (cx or marrs)
#   root                Get the project root
#   all                 List modules from docker/pom.xml (for "all" expansion)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
source "$SCRIPT_DIR/cx.lib"

usage() {
  sed -n '4,22p' "$0"
  exit 0
}

require_subarg() {
  local cmd="$1"
  local value="${2:-}"
  if [[ -z "$value" || "${value:0:1}" == "-" ]]; then
    err_msg "Usage: cxconfig $cmd <component>"
    exit 1
  fi
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" || $# -eq 0 ]] && usage

require_project_root
project_root="$PROJECT_ROOT"

# Derive deploy prefix from project path
get_prefix() {
  case "$project_root" in
    *cx-search*) echo "cx" ;;
    *marrs*)     echo "marrs" ;;
    *)
      err_msg "Cannot determine deploy prefix from project path: $project_root"
      exit 1
      ;;
  esac
}

# Read a property value from docker/pom.xml
get_docker_pom_property() {
  local prop="$1"
  sed -n "s/.*<${prop}>\(.*\)<\/${prop}>.*/\1/p" "$project_root/docker/pom.xml" | head -1
}

get_registry() {
  local registry project
  registry=$(get_docker_pom_property "docker.push.registry")
  project=$(get_docker_pom_property "docker.project")
  if [[ -z "$registry" || -z "$project" ]]; then
    err_msg "Cannot read docker.push.registry or docker.project from docker/pom.xml"
    exit 1
  fi
  echo "$registry/$project"
}

get_version() {
  local ver
  ver=$(grep -m1 '<version>' "$project_root/pom.xml" | sed 's/.*<version>\(.*\)<\/version>.*/\1/')
  if [[ -z "$ver" ]]; then
    err_msg "Cannot read version from $project_root/pom.xml"
    exit 1
  fi
  echo "$ver"
}

# Return 0 when a component can be built/pushed/deployed by the cx* helpers.
# Deployable components either define a Dockerfile directly or have a pom.xml
# that wires in the docker-maven-plugin image build flow. Modules that only
# filter resources, like redis-proxy, are intentionally excluded.
is_deployable_component() {
  local comp="$1"
  local compdir="$project_root/docker/$comp"
  [[ -f "$compdir/Dockerfile" ]] && return 0
  [[ -f "$compdir/pom.xml" ]] && grep -q "<artifactId>docker-maven-plugin</artifactId>" "$compdir/pom.xml"
}

# List deployable modules declared in docker/pom.xml
get_all_modules() {
  local module
  while IFS= read -r module; do
    is_deployable_component "$module" && echo "$module"
  done < <(sed -n 's/.*<module>\(.*\)<\/module>.*/\1/p' "$project_root/docker/pom.xml")
}

# List all components: subdirs of docker/ that have a pom.xml or Dockerfile
get_components() {
  local dir
  for dir in "$project_root"/docker/*/; do
    local name
    name=$(basename "$dir")
    [[ "$name" == "target" ]] && continue
    if [[ -f "$dir/pom.xml" || -f "$dir/Dockerfile" ]]; then
      echo "$name"
    fi
  done
}

# Verify that a component has a docker subdirectory with pom.xml or Dockerfile
require_component() {
  local comp="$1"
  local compdir="$project_root/docker/$comp"
  if [[ ! -f "$compdir/pom.xml" && ! -f "$compdir/Dockerfile" ]]; then
    err_msg "Unknown component '$comp' (no pom.xml or Dockerfile in docker/$comp)"
    exit 1
  fi
}

# Namespace from the directory name under distributions/ (excluding target/)
get_namespace() {
  local dir
  for dir in "$project_root"/distributions/*/; do
    local name
    name=$(basename "$dir")
    [[ "$name" == "target" ]] && continue
    [[ -d "$dir" ]] && echo "$name" && return
  done
  err_msg "Cannot determine namespace from distributions/"
  exit 1
}

# Deploy name convention: prefix-component, but if the component name already
# starts with the prefix, strip it first to avoid doubling.
get_deploy_name() {
  local component="$1"
  local prefix
  prefix=$(get_prefix)
  local stripped="$component"
  stripped="${stripped#"${prefix}-"}"
  if [[ "$stripped" == "$prefix" || "$component" == "$prefix" ]]; then
    echo "$prefix"
  else
    echo "${prefix}-${stripped}"
  fi
}

case "$1" in
  components)
    get_components
    ;;
  all)
    get_all_modules
    ;;
  dir)
    require_subarg "dir" "${2:-}"
    require_component "$2"
    echo "$2"
    ;;
  deploy)
    require_subarg "deploy" "${2:-}"
    require_component "$2"
    get_deploy_name "$2"
    ;;
  image)
    require_subarg "image" "${2:-}"
    component="$2"
    require_component "$component"
    echo "$(get_registry)/${component}:$(get_version)"
    ;;
  timeout)
    echo "300"
    ;;
  registry)
    get_registry
    ;;
  version)
    get_version
    ;;
  namespace)
    get_namespace
    ;;
  prefix)
    get_prefix
    ;;
  root)
    echo "$project_root"
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage
    ;;
esac
