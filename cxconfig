#!/usr/bin/env bash
set -euo pipefail

# Query component configuration for cx or marrs projects
#
# Reads components.conf from the project root directory.
# Must be run from within a project directory (walks up to find pom.xml).
#
# Usage: cxconfig <command> [args]
#
# Commands:
#   components          List all component names
#   dir <component>     Get docker directory for component
#   modules <component> Get maven modules for component
#   deploy <component>  Get k8s deployment name for component
#   image <component>   Get full image:tag (registry/dir:version)
#   timeout <component> Get rollout timeout in seconds
#   registry            Get the container registry URL
#   version             Get the current build version
#   namespace           Get the k8s namespace for this app
#   app                 Get the detected app name
#   root                Get the project root

source cx.lib

usage() {
  cat <<'EOF'
Query component configuration for cx or marrs projects

Commands:
  components          List all component names
  dir <component>     Get docker directory for component
  modules <component> Get maven modules for component
  deploy <component>  Get k8s deployment name for component
  image <component>   Get full image:tag (registry/dir:version)
  timeout <component> Get rollout timeout in seconds
  registry            Get the container registry URL
  version             Get the current build version
  namespace           Get the k8s namespace for this app
  app                 Get the detected app name
  root                Get the project root
EOF
  exit 0
}

# Handle help before requiring project root
[[ "${1:-}" == "-h" || "${1:-}" == "--help" || $# -eq 0 ]] && usage

# Require being in a project directory
require_project_root
project_root="$PROJECT_ROOT"

readonly CONFIG="$project_root/components.conf"

if [[ ! -f "$CONFIG" ]]; then
  err_msg "Config file not found: $CONFIG"
  exit 1
fi

get_setting() {
  grep "^$1=" "$CONFIG" | cut -d= -f2-
}

get_component_field() {
  local component="$1" field="$2"
  grep "^${component}:" "$CONFIG" | cut -d: -f"$field"
}

get_component_dir() {
  local component="$1"
  local dir
  dir=$(get_component_field "$component" 2)
  [[ -n "$dir" ]] || { err_msg "Unknown component '$component'"; exit 1; }
  echo "$dir"
}

get_namespace() {
  local ns
  ns=$(get_setting namespace)
  echo "${ns:-octocx}"
}

get_deploy_prefix() {
  local prefix
  prefix=$(get_setting deploy_prefix)
  echo "${prefix:-cx}"
}

get_version() {
  grep -m1 '<version>' "$project_root/pom.xml" | sed 's/.*<version>\(.*\)<\/version>.*/\1/'
}

case "$1" in
  components)
    grep -E '^[a-z].*:' "$CONFIG" | cut -d: -f1
    ;;
  dir)
    get_component_dir "${2:?Usage: cxconfig dir <component>}"
    ;;
  deploy)
    dir=$(get_component_dir "${2:?Usage: cxconfig deploy <component>}")
    prefix=$(get_deploy_prefix)
    dir="${dir#cx-}"
    dir="${dir#marrs-}"
    if [[ "$dir" == "$prefix" ]]; then
      echo "$prefix"
    else
      echo "${prefix}-${dir}"
    fi
    ;;
  image)
    dir=$(get_component_dir "${2:?Usage: cxconfig image <component>}")
    registry=$(get_setting registry)
    version=$(get_version)
    echo "$registry/$dir:$version"
    ;;
  modules)
    component="${2:?Usage: cxconfig modules <component>}"
    get_component_dir "$component" >/dev/null
    modules=$(get_component_field "$component" 3)
    echo "$modules" | tr ',' '\n'
    ;;
  timeout)
    component="${2:?Usage: cxconfig timeout <component>}"
    get_component_dir "$component" >/dev/null
    timeout=$(get_component_field "$component" 4)
    echo "${timeout:-$(get_setting default_timeout)}"
    ;;
  registry)
    get_setting registry
    ;;
  version)
    get_version
    ;;
  namespace)
    get_namespace
    ;;
  app)
    basename "$project_root"
    ;;
  root)
    echo "$project_root"
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage
    ;;
esac
