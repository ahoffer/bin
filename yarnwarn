#!/usr/bin/env perl
use strict;
use warnings;

# Suppresses the repetitive peer-dependency warnings that rarely change the
# immediate build decision at normal verbosity, while still leaving actual
# failures and opt-in detail available at higher verbosity levels.

$| = 1;

my $level = do {
    my $raw = $ENV{MVNFILTER_LEVEL} // 1;
    ($raw =~ /^[0-9]$/) ? int($raw) : 1;
};

while (my $line = <STDIN>) {
    if ($line =~ /^(?:\S+\s+)?YN(?:0002|0060|0086):/) {
        next if $level <= 3;
    }
    if ($line =~ /^(?:\S+\s+)?YN(?!0000)\d+:/) {
        next if $level <= 1;
    }
    print $line;
}
