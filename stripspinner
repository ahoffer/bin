#!/usr/bin/env perl
# Strips TUI spinner noise from session logs produced by wraplog/script(1).
#
# Background: TUI tools (claude, codex) use cursor-addressed redraws to
# animate status bars.  After escape sequences are stripped, each cursor
# move concatenates whatever was on screen at that moment onto the current
# logical line, producing three distinct noise artefacts:
#
#   1. Timer status lines
#      Raw form: ESC[row;colH <bullet> Working(Ns <bullet> esc to interrupt)
#      Stripped:                       •Working(4s • esc to interrupt)
#      These repeat once per second for every in-progress operation.
#
#   2. Progressive prefix build-up
#      The TUI builds a word one char at a time from position 0, so each
#      new frame includes all previous characters: W Wo Wor Work...Working.
#      Stripped:  WWoWorWorkWorkiWorkinWorking  (or St StaStar...Starting)
#      Pattern: a 1-or-2-char uppercase seed followed by 2+ repetitions
#      that each extend the seed by one or more lowercase chars.
#      Replace the whole run with the final (longest) token.
#
#   3. Progressive suffix teardown
#      After the full word is displayed, cursor movements cause the tail
#      chars to be dropped one by one: Working orking rking king ing ng g.
#      Stripped: •orking•rking•king•ing•ng
#      Key discriminator: a bullet (U+2022) directly before a lowercase
#      letter with no space.  Real bullets always have a space: "• Called".
#
#   4. Dense spinner lines
#      Some frames (startup animations, long waits) produce lines where
#      almost every token is noise.  These are dropped entirely when the
#      count of no-space bullets exceeds a threshold.

use strict;
use warnings;
use utf8;
binmode(STDIN,  ':encoding(UTF-8)');
binmode(STDOUT, ':encoding(UTF-8)');

my $BULLET    = "\x{2022}";  # U+2022 BULLET, used by codex/claude TUI
my $MAX_NOISE = 20;          # lines with more no-space bullets than this are dropped

while (my $line = <STDIN>) {
    chomp $line;

    # Drop lines dominated by spinner noise.  Count bullets not followed by
    # a space; real prose bullets always have a trailing space.
    my $noise_bullets = () = $line =~ /\Q$BULLET\E[^ ]/g;
    next if $noise_bullets > $MAX_NOISE;

    # Strip complete timer status: •Working(Ns • esc to interrupt)
    $line =~ s/\Q$BULLET\EWorking\(\d+s \Q$BULLET\E esc to interrupt\)//g;

    # Strip orphan timer fragment left when the full form was only partially
    # captured (cursor moved mid-write).
    $line =~ s/\(\d+s \Q$BULLET\E esc to interrupt\)//g;

    # Strip progressive prefix build-up.
    # Seed: one uppercase letter optionally followed by one lowercase letter.
    # Body: two or more repetitions of (seed + one or more lowercase chars).
    # Replace the entire run with just the final, longest token.
    # The 1 while loop handles nested or adjacent build-ups in one pass.
    1 while $line =~ s{([A-Z][a-z]?)((?:\1[a-z]+){2,})}{
        my ($seed, $rest) = ($1, $2);
        my ($last) = ($rest =~ /([A-Z][a-z]+)$/);
        defined($last) ? $last : ($seed . $rest)
    }gex;

    # Strip progressive suffix teardown.
    # Four or more (bullet + short all-alpha fragment) sequences with no space
    # after the bullet are exclusively spinner noise.  Real bullets have a
    # space: "• Called" vs "•orking".  Using 4 as threshold avoids false
    # positives from ordinary prose that might use 3 consecutive inline icons.
    $line =~ s/(?:\Q$BULLET\E[A-Za-z]{1,8}){4,}//g;

    # Collapse any doubled bullets created by the removals above.
    $line =~ s/(?:\Q$BULLET\E){2,}/$BULLET/g;

    $line =~ s/\s+$//;
    print "$line\n" if length $line;
}
